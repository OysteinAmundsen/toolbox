---
/**
 * FullscreenButton.astro — Reusable viewport-fill toggle (CSS-based, not the
 * native Fullscreen API).
 *
 * Renders a small button that, on click, expands the closest matching ancestor
 * to fill the browser viewport via `position: fixed; inset: 0`. Escape exits.
 *
 * Why not the native Fullscreen API:
 *  - Triggers OS-level fullscreen (the F11 behaviour), which is more invasive
 *    than what a docs demo needs.
 *  - The browser only paints the fullscreen subtree; anything mounted on
 *    `document.body` outside that subtree (popovers, portaled filter panels,
 *    tooltips) becomes invisible. The grid's filter panel is one such example.
 *
 * Usage:
 * ```astro
 * <div class="my-container">
 *   <FullscreenButton target=".my-container" />
 *   <tbw-grid></tbw-grid>
 * </div>
 * ```
 */
interface Props {
  /** CSS selector for the element to fullscreen (resolved via `.closest()` from the button) */
  target: string;
  /** Button tooltip / accessible label */
  label?: string;
}

const { target, label = 'Open in fullscreen' } = Astro.props;
---

<button
  class="fullscreen-btn"
  data-fs-target={target}
  type="button"
  title={label}
  aria-label={label}
>
  <svg class="fullscreen-btn__expand" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="15 3 21 3 21 9" />
    <polyline points="9 21 3 21 3 15" />
    <line x1="21" y1="3" x2="14" y2="10" />
    <line x1="3" y1="21" x2="10" y2="14" />
  </svg>
  <svg class="fullscreen-btn__collapse" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="4 14 10 14 10 20" />
    <polyline points="20 10 14 10 14 4" />
    <line x1="14" y1="10" x2="21" y2="3" />
    <line x1="3" y1="21" x2="10" y2="14" />
  </svg>
</button>

<script>
  const FS_CLASS = 'is-fullscreen';
  const BTN_ACTIVE_CLASS = 'fullscreen-btn--active';
  const PLACEHOLDER_ATTR = 'data-fs-placeholder-for';

  function syncButton(btn: HTMLButtonElement, isFullscreen: boolean) {
    btn.classList.toggle(BTN_ACTIVE_CLASS, isFullscreen);
    btn.title = isFullscreen ? 'Exit fullscreen' : 'Open in fullscreen';
    btn.setAttribute('aria-label', isFullscreen ? 'Exit fullscreen' : 'Open in fullscreen');
  }

  /**
   * Track the target's original DOM location so we can restore it on exit.
   * We move the target out to `document.body` while expanded — otherwise an
   * ancestor with `transform`/`filter`/`contain` (Starlight's layout has these)
   * traps `position: fixed` to its own box instead of the viewport.
   */
  const placeholders = new WeakMap<Element, HTMLElement>();

  function exitFullscreen(target: Element) {
    target.classList.remove(FS_CLASS);
    document.body.classList.remove('has-fullscreen-target');
    const btn = target.querySelector<HTMLButtonElement>('.fullscreen-btn');
    if (btn) syncButton(btn, false);

    // Restore to original location.
    const placeholder = placeholders.get(target);
    if (placeholder && placeholder.parentNode) {
      placeholder.parentNode.replaceChild(target, placeholder);
      placeholders.delete(target);
    }
  }

  function enterFullscreen(target: Element, btn: HTMLButtonElement) {
    // Only one viewport-filling target at a time.
    for (const other of document.querySelectorAll(`.${FS_CLASS}`)) {
      if (other !== target) exitFullscreen(other);
    }

    // Leave a placeholder behind so we can restore the target to its exact
    // DOM position when the user exits.
    const placeholder = document.createElement('div');
    placeholder.setAttribute(PLACEHOLDER_ATTR, '');
    placeholder.style.display = 'none';
    target.parentNode?.insertBefore(placeholder, target);
    placeholders.set(target, placeholder);

    document.body.appendChild(target);
    target.classList.add(FS_CLASS);
    document.body.classList.add('has-fullscreen-target');
    syncButton(btn, true);
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.fullscreen-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const selector = btn.dataset.fsTarget;
    if (!selector) return;

    const target = btn.closest(selector);
    if (!target) return;

    if (target.classList.contains(FS_CLASS)) {
      exitFullscreen(target);
    } else {
      enterFullscreen(target, btn);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const active = document.querySelector(`.${FS_CLASS}`);
    if (active) {
      e.preventDefault();
      exitFullscreen(active);
    }
  });
</script>

<style>
  .fullscreen-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    line-height: 1;
  }

  .fullscreen-btn:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-gray-5);
  }

  .fullscreen-btn:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  /* Toggle expand/collapse icons */
  .fullscreen-btn__collapse {
    display: none;
  }

  .fullscreen-btn--active .fullscreen-btn__expand {
    display: none;
  }

  .fullscreen-btn--active .fullscreen-btn__collapse {
    display: block;
  }
</style>

<!--
  Global rules so consumers can simply target `.my-container.is-fullscreen` to
  layer additional fullscreen styling on top of the base viewport-fill. Loaded
  once because <style is:global> hoists to the page.

  The element is moved to `<body>` while expanded (see script above) so
  `body > .is-fullscreen` matches and gives us the specificity (0,1,1) needed
  to win over per-component scoped rules that set `position: relative` on the
  target (e.g. `.show-source-wrapper`).
-->
<style is:global>
  body > .is-fullscreen {
    position: fixed;
    inset: 0;
    z-index: 9999;
    margin: 0;
    overflow: auto;
    background: var(--sl-color-bg, #fff);
    box-sizing: border-box;
  }

  /* Prevent background scroll while a target is expanded. */
  body.has-fullscreen-target {
    overflow: hidden;
  }
</style>
