---
/**
 * ThemeBuilder.astro — Interactive theme builder for @toolbox-web/grid
 *
 * Ported from ThemeBuilder.stories.ts. Lets users customize all CSS variables
 * and export the result as a reusable theme CSS file.
 */
import FullscreenButton from './FullscreenButton.astro';
---

<div class="theme-builder-container not-content" id="theme-builder">
  <div class="theme-builder-toolbar" id="tb-toolbar" style="display:none;">
    <span class="theme-builder-toolbar__label">Export Theme:</span>
    <button class="theme-builder-btn" id="tb-copy">📋 Copy CSS</button>
    <button class="theme-builder-btn" id="tb-download">💾 Download CSS</button>
    <button class="theme-builder-btn" id="tb-preview">👁 Preview CSS</button>
    <button class="theme-builder-btn" id="tb-reset" style="margin-left:auto;">↺ Reset</button>
    <FullscreenButton target=".theme-builder-container" label="Open theme builder in fullscreen" />
  </div>
  <div class="theme-builder-main">
    <div class="theme-builder-grid-wrapper">
      <tbw-grid id="tb-grid" style="height: 100%;"></tbw-grid>
    </div>
    <div id="tb-panel-slot"></div>
  </div>
  <div id="tb-a11y-slot"></div>
</div>

<script>
  import '@toolbox-web/grid';
import type { ColumnConfig, GridConfig, ShellConfig } from '@toolbox-web/grid';
import {
ContextMenuPlugin,
ExportPlugin,
FilteringPlugin,
MasterDetailPlugin,
MultiSortPlugin,
PinnedColumnsPlugin,
SelectionPlugin,
VisibilityPlugin,
} from '@toolbox-web/grid/all';

  // #region Types & Data
  interface Employee {
    id: number;
    name: string;
    department: string;
    role: string;
    salary: number;
    startDate: string;
    status: 'active' | 'inactive' | 'on-leave';
    rating: number;
    email: string;
  }

  const DEPARTMENTS = ['Engineering', 'Sales', 'Marketing', 'HR', 'Finance'];
  const ROLES = ['Manager', 'Senior', 'Junior', 'Lead', 'Director'];
  const STATUSES: Employee['status'][] = ['active', 'inactive', 'on-leave'];

  function generateEmployees(count: number): Employee[] {
    return Array.from({ length: count }, (_, i) => ({
      id: i + 1,
      name: `Employee ${i + 1}`,
      department: DEPARTMENTS[i % DEPARTMENTS.length],
      role: ROLES[i % ROLES.length],
      salary: 50000 + Math.floor(Math.random() * 100000),
      startDate: new Date(2020 + Math.floor(Math.random() * 5), Math.floor(Math.random() * 12), 1)
        .toISOString()
        .split('T')[0],
      status: STATUSES[i % STATUSES.length],
      rating: 1 + Math.floor(Math.random() * 5),
      email: `employee${i + 1}@company.com`,
    }));
  }

  const employees = generateEmployees(100);

  const columns: ColumnConfig<Employee>[] = [
    { field: 'id', header: 'ID', width: 60, pinned: 'left' },
    { field: 'name', header: 'Name', width: 150 },
    { field: 'department', header: 'Department', width: 120 },
    { field: 'role', header: 'Role', width: 100 },
    {
      field: 'salary',
      header: 'Salary',
      width: 100,
      align: 'right',
      renderer: ({ value }) => `$${(value as number).toLocaleString()}`,
    },
    { field: 'startDate', header: 'Start Date', width: 110 },
    {
      field: 'status',
      header: 'Status',
      width: 90,
      renderer: ({ value, cellEl }) => {
        const colors: Record<string, string> = {
          active: 'var(--tbw-color-success)',
          inactive: 'var(--tbw-color-fg-muted)',
          'on-leave': 'var(--tbw-color-accent)',
        };
        cellEl.style.color = colors[value as string] || '';
        return (value as string).charAt(0).toUpperCase() + (value as string).slice(1);
      },
    },
    {
      field: 'rating',
      header: 'Rating',
      width: 80,
      align: 'center',
      renderer: ({ value }) => '★'.repeat(value as number) + '☆'.repeat(5 - (value as number)),
    },
    { field: 'email', header: 'Email', width: 180 },
  ];
  // #endregion

  // #region CSS Variable Definitions
  import { CSS_VARIABLES } from '../data/css-variable-registry.js';
  // #endregion

  // #region State & Helpers
  interface ThemeState {
    themeName: string;
    darkModeSupport: boolean;
    values: Record<string, string>;
    darkValues: Record<string, string>;
    baselineValues: Record<string, string>;
    baselineDarkValues: Record<string, string>;
  }

  function toArgName(varName: string): string {
    return varName.replace('--tbw-', '').replace(/-([a-z])/g, (_, l) => l.toUpperCase());
  }

  function normalizeColor(color: string): string {
    if (color.startsWith('#') && color.length === 7) return color;
    if (color === 'transparent') return '#ffffff';
    const canvas = document.createElement('canvas');
    canvas.width = 1;
    canvas.height = 1;
    const ctx = canvas.getContext('2d');
    if (ctx) {
      ctx.fillStyle = color;
      ctx.fillRect(0, 0, 1, 1);
      const d = ctx.getImageData(0, 0, 1, 1).data;
      return `#${d[0].toString(16).padStart(2, '0')}${d[1].toString(16).padStart(2, '0')}${d[2].toString(16).padStart(2, '0')}`;
    }
    return '#000000';
  }

  function readComputedVariables(element: HTMLElement): { light: Record<string, string>; dark: Record<string, string> } {
    const light: Record<string, string> = {};
    const dark: Record<string, string> = {};

    const normalize = (computed: string): string => {
      const rgbaMatch = computed.match(/rgba\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*,\s*([\d.]+)\s*\)/i);
      if (rgbaMatch) {
        if (parseFloat(rgbaMatch[4]) < 1) return computed;
        const [, r, g, b] = rgbaMatch;
        return `#${[r, g, b].map((x) => parseInt(x).toString(16).padStart(2, '0')).join('')}`;
      }
      const rgbMatch = computed.match(/rgb\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*\)/i);
      if (rgbMatch) {
        const [, r, g, b] = rgbMatch;
        return `#${[r, g, b].map((x) => parseInt(x).toString(16).padStart(2, '0')).join('')}`;
      }
      return '';
    };

    const isValid = (c: string) => c && c.length > 0 && c !== '#000000' && c !== 'rgba(0, 0, 0, 0)';

    const probe = document.createElement('span');
    probe.style.cssText = 'position:absolute;visibility:hidden;pointer-events:none;';
    element.appendChild(probe);

    const readColors = (target: Record<string, string>, isDark: boolean) => {
      for (const category of Object.values(CSS_VARIABLES)) {
        for (const variable of category) {
          const argName = toArgName(variable.name);
          if (variable.type === 'color') {
            probe.style.backgroundColor = `var(${variable.name})`;
            void probe.offsetHeight;
            const computed = getComputedStyle(probe).backgroundColor;
            const normalized = normalize(computed);
            if (isValid(normalized)) {
              target[argName] = normalized;
            } else {
              target[argName] = variable.defaultValue === 'transparent' ? (isDark ? '#222222' : '#ffffff') : variable.defaultValue;
            }
          } else {
            const raw = getComputedStyle(element).getPropertyValue(variable.name).trim();
            target[argName] = raw || variable.defaultValue;
          }
        }
      }
    };

    const origScheme = element.style.colorScheme;
    element.style.colorScheme = 'light';
    void element.offsetHeight;
    readColors(light, false);
    element.style.colorScheme = 'dark';
    void element.offsetHeight;
    readColors(dark, true);
    origScheme ? (element.style.colorScheme = origScheme) : element.style.removeProperty('color-scheme');
    element.removeChild(probe);
    return { light, dark };
  }

  function generateCSSFromState(state: ThemeState): string {
    const lines: string[] = [
      `/*`,
      ` * Custom Theme: ${state.themeName}`,
      ` * Generated by @toolbox-web/grid Theme Builder`,
      ` * ${new Date().toISOString().split('T')[0]}`,
      state.darkModeSupport ? ` * Dark mode: enabled (uses light-dark() CSS function)` : ` * Dark mode: disabled`,
      ` */`,
      `@layer tbw-theme {`,
      `  tbw-grid.${state.themeName},`,
      `  .${state.themeName} tbw-grid {`,
    ];

    for (const [category, variables] of Object.entries(CSS_VARIABLES)) {
      const catLines: string[] = [];
      for (const variable of variables) {
        const argName = toArgName(variable.name);
        const lightVal = state.values[argName];
        const darkVal = state.darkValues[argName];
        const baseLight = state.baselineValues[argName] || variable.defaultValue;
        const baseDark = state.baselineDarkValues[argName] || variable.defaultValue;

        if (variable.type === 'color') {
          const lightChanged = lightVal && lightVal !== baseLight;
          const darkChanged = darkVal && darkVal !== baseDark;
          if (state.darkModeSupport) {
            if (lightChanged || darkChanged) {
              catLines.push(`    ${variable.name}: light-dark(${lightVal || baseLight}, ${darkVal || baseDark});`);
            }
          } else if (lightChanged) {
            catLines.push(`    ${variable.name}: ${lightVal};`);
          }
        } else {
          if (lightVal && lightVal !== baseLight) {
            catLines.push(`    ${variable.name}: ${lightVal};`);
          }
        }
      }
      if (catLines.length > 0) {
        lines.push(`    /* ${category} */`);
        lines.push(...catLines);
      }
    }
    lines.push(`  }`);
    lines.push(`}`);
    return lines.join('\n');
  }

  function applyStateToGrid(grid: HTMLElement, state: ThemeState): void {
    for (const category of Object.values(CSS_VARIABLES)) {
      for (const variable of category) {
        const argName = toArgName(variable.name);
        const lightVal = state.values[argName] || variable.defaultValue;
        const darkVal = state.darkValues[argName] || variable.defaultValue;
        grid.style.setProperty(
          variable.name,
          variable.type === 'color' && state.darkModeSupport ? `light-dark(${lightVal}, ${darkVal})` : lightVal,
        );
      }
    }
  }
  // #endregion

  // #region WCAG Contrast Utilities
  interface ContrastPair { name: string; description: string; foreground: string; background: string; }

  const CONTRAST_PAIRS: ContrastPair[] = [
    { name: 'Body Text', description: 'Primary text on panel background', foreground: '--tbw-color-fg', background: '--tbw-color-panel-bg' },
    { name: 'Muted Text', description: 'Secondary text on panel background', foreground: '--tbw-color-fg-muted', background: '--tbw-color-panel-bg' },
    { name: 'Header Text', description: 'Header text on header background', foreground: '--tbw-color-header-fg', background: '--tbw-color-header-bg' },
    { name: 'Hover Row Text', description: 'Text on hovered row', foreground: '--tbw-color-fg', background: '--tbw-color-row-hover' },
    { name: 'Selected Row Text', description: 'Text on selected row', foreground: '--tbw-color-fg', background: '--tbw-color-selection' },
    { name: 'Accent Contrast', description: 'Text on accent-colored background', foreground: '--tbw-color-accent-fg', background: '--tbw-color-accent' },
  ];

  function parseColorToRGBA(color: string): { r: number; g: number; b: number; a: number } | null {
    if (!color || color === 'transparent') return null;
    if (color.startsWith('#')) {
      let hex = color.slice(1);
      if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
      if (hex.length === 6) return { r: parseInt(hex.slice(0, 2), 16), g: parseInt(hex.slice(2, 4), 16), b: parseInt(hex.slice(4, 6), 16), a: 1 };
      if (hex.length === 8) return { r: parseInt(hex.slice(0, 2), 16), g: parseInt(hex.slice(2, 4), 16), b: parseInt(hex.slice(4, 6), 16), a: parseInt(hex.slice(6, 8), 16) / 255 };
    }
    const rgbaMatch = color.match(/rgba\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*,\s*([\d.]+)\s*\)/i);
    if (rgbaMatch) return { r: parseInt(rgbaMatch[1]), g: parseInt(rgbaMatch[2]), b: parseInt(rgbaMatch[3]), a: parseFloat(rgbaMatch[4]) };
    const rgbMatch = color.match(/rgb\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*\)/i);
    if (rgbMatch) return { r: parseInt(rgbMatch[1]), g: parseInt(rgbMatch[2]), b: parseInt(rgbMatch[3]), a: 1 };
    return null;
  }

  function compositeColors(fg: { r: number; g: number; b: number; a: number }, bg: { r: number; g: number; b: number }) {
    const a = fg.a;
    return { r: Math.round(fg.r * a + bg.r * (1 - a)), g: Math.round(fg.g * a + bg.g * (1 - a)), b: Math.round(fg.b * a + bg.b * (1 - a)) };
  }

  function getRelativeLuminance(r: number, g: number, b: number): number {
    const [rs, gs, bs] = [r, g, b].map(c => { const s = c / 255; return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4); });
    return 0.2126 * rs + 0.7152 * gs + 0.0722 * bs;
  }

  function getContrastRatio(fg: string, bg: string, panelBg?: string): number | null {
    const fgRgba = parseColorToRGBA(fg);
    const bgRgba = parseColorToRGBA(bg);
    if (!fgRgba || !bgRgba) return null;
    let effectiveBg: { r: number; g: number; b: number };
    if (bgRgba.a < 1 && panelBg) {
      const p = parseColorToRGBA(panelBg);
      effectiveBg = p ? compositeColors(bgRgba, p) : bgRgba;
    } else {
      effectiveBg = bgRgba;
    }
    const l1 = getRelativeLuminance(fgRgba.r, fgRgba.g, fgRgba.b);
    const l2 = getRelativeLuminance(effectiveBg.r, effectiveBg.g, effectiveBg.b);
    return (Math.max(l1, l2) + 0.05) / (Math.min(l1, l2) + 0.05);
  }

  type WCAGLevel = 'AAA' | 'AA' | 'AA-large' | 'fail';
  function getWCAGLevel(ratio: number): WCAGLevel {
    if (ratio >= 7) return 'AAA';
    if (ratio >= 4.5) return 'AA';
    if (ratio >= 3) return 'AA-large';
    return 'fail';
  }
  // #endregion

  // #region Panel Builder
  function createThemePanel(state: ThemeState, onUpdate: () => void): HTMLElement {
    const panel = document.createElement('div');
    panel.className = 'theme-builder-panel theme-builder-panel--dark-mode';

    // Header
    const header = document.createElement('div');
    header.className = 'theme-builder-panel__header';

    const toggleBtn = document.createElement('button');
    toggleBtn.className = 'theme-builder-panel__toggle';
    toggleBtn.textContent = '◀';
    toggleBtn.title = 'Collapse panel';
    toggleBtn.addEventListener('click', () => {
      panel.classList.toggle('theme-builder-panel--collapsed');
      toggleBtn.textContent = panel.classList.contains('theme-builder-panel--collapsed') ? '▶' : '◀';
    });
    header.appendChild(toggleBtn);

    const title = document.createElement('span');
    title.className = 'theme-builder-panel__title';
    title.textContent = 'Theme Variables';
    header.appendChild(title);

    const controls = document.createElement('div');
    controls.className = 'theme-builder-panel__controls';

    const nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.value = state.themeName;
    nameInput.className = 'theme-builder-var-row__input';
    nameInput.style.width = '100px';
    nameInput.placeholder = 'Theme name';
    nameInput.addEventListener('input', () => { state.themeName = nameInput.value; });
    controls.appendChild(nameInput);

    const darkToggle = document.createElement('label');
    darkToggle.className = 'theme-builder-dark-toggle';
    const darkCheckbox = document.createElement('input');
    darkCheckbox.type = 'checkbox';
    darkCheckbox.checked = state.darkModeSupport;
    darkCheckbox.addEventListener('change', () => {
      state.darkModeSupport = darkCheckbox.checked;
      panel.classList.toggle('theme-builder-panel--dark-mode', darkCheckbox.checked);
      onUpdate();
    });
    darkToggle.appendChild(darkCheckbox);
    darkToggle.appendChild(document.createTextNode('Dark'));
    controls.appendChild(darkToggle);

    header.appendChild(controls);
    panel.appendChild(header);

    const content = document.createElement('div');
    content.className = 'theme-builder-panel__content';

    for (const [category, variables] of Object.entries(CSS_VARIABLES)) {
      const categoryEl = document.createElement('div');
      categoryEl.className = 'theme-builder-category';

      const catHeader = document.createElement('div');
      catHeader.className = 'theme-builder-category__header';
      catHeader.addEventListener('click', () => categoryEl.classList.toggle('theme-builder-category--open'));

      const chevron = document.createElement('span');
      chevron.className = 'theme-builder-category__chevron';
      chevron.textContent = '▶';
      catHeader.appendChild(chevron);

      const name = document.createElement('span');
      name.className = 'theme-builder-category__name';
      name.textContent = category;
      catHeader.appendChild(name);

      const count = document.createElement('span');
      count.className = 'theme-builder-category__count';
      count.textContent = String(variables.length);
      catHeader.appendChild(count);

      categoryEl.appendChild(catHeader);

      const items = document.createElement('div');
      items.className = 'theme-builder-category__items';

      for (const variable of variables) {
        const argName = toArgName(variable.name);

        if (variable.type === 'color') {
          const row = document.createElement('div');
          row.className = 'theme-builder-color-row';

          const label = document.createElement('div');
          label.className = 'theme-builder-color-row__label';
          label.innerHTML = `<code>${variable.name.replace('--tbw-', '')}</code>`;
          label.title = variable.description;
          row.appendChild(label);

          const pickers = document.createElement('div');
          pickers.className = 'theme-builder-color-row__pickers';

          const createPicker = (mode: 'light' | 'dark', getValue: () => string, setValue: (v: string) => void) => {
            const picker = document.createElement('div');
            picker.className = mode === 'dark' ? 'theme-builder-color-picker theme-builder-color-picker--dark' : 'theme-builder-color-picker';

            const modeLabel = document.createElement('span');
            modeLabel.className = 'theme-builder-color-picker__label';
            modeLabel.textContent = mode === 'light' ? 'Light' : 'Dark';
            picker.appendChild(modeLabel);

            const wrapper = document.createElement('div');
            wrapper.className = 'theme-builder-color-picker__wrapper';

            const colorInput = document.createElement('input');
            colorInput.type = 'color';
            colorInput.className = 'theme-builder-color-picker__input';
            const currentValue = getValue();
            const isCleared = currentValue === 'transparent';
            colorInput.value = isCleared ? '#ffffff' : normalizeColor(currentValue);
            colorInput.disabled = isCleared;
            colorInput.addEventListener('input', () => { setValue(colorInput.value); onUpdate(); });
            wrapper.appendChild(colorInput);

            const transparentLabel = document.createElement('label');
            transparentLabel.className = 'theme-builder-color-picker__transparent';
            const transparentCheck = document.createElement('input');
            transparentCheck.type = 'checkbox';
            transparentCheck.checked = isCleared;
            transparentCheck.title = 'Set to transparent';
            transparentCheck.addEventListener('change', () => {
              if (transparentCheck.checked) { setValue('transparent'); colorInput.disabled = true; }
              else { setValue(colorInput.value); colorInput.disabled = false; }
              onUpdate();
            });
            transparentLabel.appendChild(transparentCheck);
            const tLabel = document.createElement('span');
            tLabel.className = 'theme-builder-color-picker__transparent-label';
            tLabel.textContent = '∅';
            tLabel.title = 'Transparent';
            transparentLabel.appendChild(tLabel);
            wrapper.appendChild(transparentLabel);

            picker.appendChild(wrapper);
            return picker;
          };

          pickers.appendChild(createPicker('light', () => state.values[argName] || variable.defaultValue, (v) => { state.values[argName] = v; }));
          pickers.appendChild(createPicker('dark', () => state.darkValues[argName] || variable.defaultValue, (v) => { state.darkValues[argName] = v; }));
          row.appendChild(pickers);
          items.appendChild(row);
        } else {
          const row = document.createElement('div');
          row.className = 'theme-builder-var-row';

          const label = document.createElement('div');
          label.className = 'theme-builder-var-row__label';
          label.innerHTML = `<code>${variable.name.replace('--tbw-', '')}</code>`;
          label.title = variable.description;
          row.appendChild(label);

          if (variable.type === 'select' && variable.options) {
            const select = document.createElement('select');
            select.className = 'theme-builder-var-row__select';
            for (const opt of variable.options) {
              const option = document.createElement('option');
              option.value = opt;
              option.textContent = opt;
              if (opt === (state.values[argName] || variable.defaultValue)) option.selected = true;
              select.appendChild(option);
            }
            select.addEventListener('change', () => { state.values[argName] = select.value; onUpdate(); });
            row.appendChild(select);
          } else {
            const input = document.createElement('input');
            input.type = 'text';
            input.className = 'theme-builder-var-row__input';
            input.value = state.values[argName] || variable.defaultValue;
            input.addEventListener('input', () => { state.values[argName] = input.value; onUpdate(); });
            row.appendChild(input);
          }
          items.appendChild(row);
        }
      }

      categoryEl.appendChild(items);
      content.appendChild(categoryEl);
    }

    panel.appendChild(content);

    if (!state.darkModeSupport) panel.classList.remove('theme-builder-panel--dark-mode');
    return panel;
  }
  // #endregion

  // #region Accessibility Panel
  function createA11yPanel(state: ThemeState): { el: HTMLElement; rebuild: () => void } {
    const wrapper = document.createElement('div');
    wrapper.className = 'theme-builder-a11y';

    // Header with collapse toggle
    const header = document.createElement('div');
    header.className = 'theme-builder-a11y__header';

    const toggleBtn = document.createElement('button');
    toggleBtn.className = 'theme-builder-a11y__toggle';
    toggleBtn.textContent = '▼';
    toggleBtn.title = 'Collapse accessibility panel';
    toggleBtn.addEventListener('click', () => {
      wrapper.classList.toggle('theme-builder-a11y--collapsed');
      toggleBtn.textContent = wrapper.classList.contains('theme-builder-a11y--collapsed') ? '▲' : '▼';
    });
    header.appendChild(toggleBtn);

    const title = document.createElement('span');
    title.className = 'theme-builder-a11y__title';
    title.textContent = '♿ Accessibility — WCAG Contrast';
    header.appendChild(title);

    const legendEl = document.createElement('div');
    legendEl.className = 'theme-builder-a11y__legend';
    legendEl.innerHTML = `
      <span class="theme-builder-a11y-badge theme-builder-a11y-badge--aaa">✓ AAA</span>
      <span class="theme-builder-a11y-badge theme-builder-a11y-badge--pass">✓ AA</span>
      <span class="theme-builder-a11y-badge theme-builder-a11y-badge--large">⚠ Lg</span>
      <span class="theme-builder-a11y-badge theme-builder-a11y-badge--fail">✗ Fail</span>
    `;
    header.appendChild(legendEl);

    wrapper.appendChild(header);

    const content = document.createElement('div');
    content.className = 'theme-builder-a11y__content';
    wrapper.appendChild(content);

    const getColorValue = (varName: string, isDark: boolean): string => {
      const an = toArgName(varName);
      if (isDark) return state.darkValues[an] || state.values[an] || getDefault(varName);
      return state.values[an] || getDefault(varName);
    };

    const getDefault = (varName: string): string => {
      for (const cat of Object.values(CSS_VARIABLES)) for (const v of cat) if (v.name === varName) return v.defaultValue;
      return '#000000';
    };

    const resolveColor = (css: string): string => {
      if (!css || css === 'transparent') return '#ffffff';
      if (css.startsWith('#')) return css.length === 4 ? `#${css[1]}${css[1]}${css[2]}${css[2]}${css[3]}${css[3]}` : css;
      const probe = document.createElement('span');
      probe.style.cssText = 'position:absolute;visibility:hidden;pointer-events:none;color:' + css;
      document.body.appendChild(probe);
      const comp = getComputedStyle(probe).color;
      document.body.removeChild(probe);
      const m = comp.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
      return m ? `#${[m[1], m[2], m[3]].map(x => parseInt(x).toString(16).padStart(2, '0')).join('')}` : css;
    };

    const createBadge = (ratio: number | null, level: WCAGLevel | null, mode: string): HTMLElement => {
      const badge = document.createElement('div');
      badge.className = 'theme-builder-a11y-badge';
      if (ratio === null || level === null) {
        badge.classList.add('theme-builder-a11y-badge--unknown');
        badge.textContent = '?';
        return badge;
      }
      const rt = ratio.toFixed(1) + ':1';
      switch (level) {
        case 'AAA': badge.classList.add('theme-builder-a11y-badge--aaa'); badge.innerHTML = '✓ AAA'; badge.title = `${mode}: ${rt}`; break;
        case 'AA': badge.classList.add('theme-builder-a11y-badge--pass'); badge.innerHTML = '✓ AA'; badge.title = `${mode}: ${rt}`; break;
        case 'AA-large': badge.classList.add('theme-builder-a11y-badge--large'); badge.innerHTML = '⚠ Lg'; badge.title = `${mode}: ${rt}`; break;
        case 'fail': badge.classList.add('theme-builder-a11y-badge--fail'); badge.innerHTML = '✗'; badge.title = `${mode}: ${rt}`; break;
      }
      return badge;
    };

    const rebuild = () => {
      content.innerHTML = '';
      for (const pair of CONTRAST_PAIRS) {
        const card = document.createElement('div');
        card.className = 'theme-builder-a11y-card';
        card.title = pair.description;

        const nameEl = document.createElement('div');
        nameEl.className = 'theme-builder-a11y-card__name';
        nameEl.textContent = pair.name;
        card.appendChild(nameEl);

        const badges = document.createElement('div');
        badges.className = 'theme-builder-a11y-card__badges';

        const lightFg = resolveColor(getColorValue(pair.foreground, false));
        const lightBg = getColorValue(pair.background, false);
        const lightPanelBg = getColorValue('--tbw-color-panel-bg', false);
        const lightRatio = getContrastRatio(lightFg, lightBg, lightPanelBg);
        const lightLevel = lightRatio !== null ? getWCAGLevel(lightRatio) : null;

        const lightGroup = document.createElement('div');
        lightGroup.className = 'theme-builder-a11y-card__mode';
        const lightLabel = document.createElement('span');
        lightLabel.className = 'theme-builder-a11y-card__mode-label';
        lightLabel.textContent = '☀';
        lightGroup.appendChild(lightLabel);
        lightGroup.appendChild(createBadge(lightRatio, lightLevel, 'Light'));
        badges.appendChild(lightGroup);

        if (state.darkModeSupport) {
          const darkFg = resolveColor(getColorValue(pair.foreground, true));
          const darkBg = getColorValue(pair.background, true);
          const darkPanelBg = getColorValue('--tbw-color-panel-bg', true);
          const darkRatio = getContrastRatio(darkFg, darkBg, darkPanelBg);
          const darkLevel = darkRatio !== null ? getWCAGLevel(darkRatio) : null;

          const darkGroup = document.createElement('div');
          darkGroup.className = 'theme-builder-a11y-card__mode';
          const darkLabel = document.createElement('span');
          darkLabel.className = 'theme-builder-a11y-card__mode-label';
          darkLabel.textContent = '🌙';
          darkGroup.appendChild(darkLabel);
          darkGroup.appendChild(createBadge(darkRatio, darkLevel, 'Dark'));
          badges.appendChild(darkGroup);
        }

        card.appendChild(badges);
        content.appendChild(card);
      }
    };

    rebuild();
    return { el: wrapper, rebuild };
  }
  // #endregion

  // #region Clipboard & Download
  function copyToClipboard(text: string, button: HTMLButtonElement): void {
    navigator.clipboard.writeText(text).then(() => {
      const orig = button.textContent;
      button.textContent = '✓ Copied!';
      button.classList.add('theme-builder-btn--success');
      setTimeout(() => { button.textContent = orig; button.classList.remove('theme-builder-btn--success'); }, 2000);
    });
  }

  function downloadCSS(css: string, filename: string): void {
    const blob = new Blob([css], { type: 'text/css' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }
  // #endregion

  // #region Initialize
  const grid = document.getElementById('tb-grid') as HTMLElement & {
    rows: Employee[];
    gridConfig: GridConfig<Employee>;
    ready: () => Promise<void>;
  };
  const toolbar = document.getElementById('tb-toolbar')!;
  const panelSlot = document.getElementById('tb-panel-slot')!;

  grid.gridConfig = {
    columns,
    defaultColDef: { sortable: true, resizable: true, filterable: true },
    shell: {
      header: { title: 'Theme Builder Preview' },
      toolPanel: { position: 'right' },
    } satisfies ShellConfig,
    plugins: [
      new SelectionPlugin({ mode: 'row' }),
      new FilteringPlugin(),
      new MultiSortPlugin(),
      new PinnedColumnsPlugin(),
      new VisibilityPlugin(),
      new ExportPlugin(),
      new ContextMenuPlugin(),
      new MasterDetailPlugin({
        detailRenderer: (row: Employee) => {
          const div = document.createElement('div');
          div.style.padding = '16px';
          div.innerHTML = `<h4 style="margin:0 0 8px">Employee Details</h4><p><strong>Name:</strong> ${row.name}</p><p><strong>Department:</strong> ${row.department}</p><p><strong>Email:</strong> ${row.email}</p>`;
          return div;
        },
      }),
    ],
  };
  grid.rows = employees;

  const state: ThemeState = {
    themeName: 'my-custom-theme',
    darkModeSupport: true,
    values: {},
    darkValues: {},
    baselineValues: {},
    baselineDarkValues: {},
  };

  let panelEl: HTMLElement | null = null;
  let a11yPanel: { el: HTMLElement; rebuild: () => void } | null = null;

  const handleUpdate = () => {
    applyStateToGrid(grid, state);
    a11yPanel?.rebuild();
  };

  const resetToBaseline = () => {
    state.values = { ...state.baselineValues };
    state.darkValues = { ...state.baselineDarkValues };
    applyStateToGrid(grid, state);
    if (panelEl) {
      const newPanel = createThemePanel(state, handleUpdate);
      panelEl.replaceWith(newPanel);
      panelEl = newPanel;
    }
    a11yPanel?.rebuild();
  };

  // Wait for grid to render, then read computed values and build panel
  requestAnimationFrame(() => {
    const computed = readComputedVariables(grid);
    state.values = { ...computed.light };
    state.darkValues = { ...computed.dark };
    state.baselineValues = { ...computed.light };
    state.baselineDarkValues = { ...computed.dark };

    // Show toolbar
    toolbar.style.display = '';

    // Wire up toolbar buttons
    document.getElementById('tb-copy')!.addEventListener('click', () => {
      copyToClipboard(generateCSSFromState(state), document.getElementById('tb-copy') as HTMLButtonElement);
    });
    document.getElementById('tb-download')!.addEventListener('click', () => {
      downloadCSS(generateCSSFromState(state), `${state.themeName}.css`);
    });
    document.getElementById('tb-preview')!.addEventListener('click', () => {
      const css = generateCSSFromState(state);
      const modal = document.createElement('div');
      modal.className = 'theme-builder-modal';
      modal.addEventListener('click', (e) => { if (e.target === modal) modal.remove(); });
      const mc = document.createElement('div');
      mc.className = 'theme-builder-modal__content';
      mc.innerHTML = `<h3 class="theme-builder-modal__title">Generated CSS</h3>`;
      const pre = document.createElement('pre');
      pre.className = 'theme-builder-modal__code';
      pre.textContent = css;
      mc.appendChild(pre);
      const closeBtn = document.createElement('button');
      closeBtn.textContent = 'Close';
      closeBtn.className = 'theme-builder-btn theme-builder-btn--primary';
      closeBtn.style.marginTop = '12px';
      closeBtn.addEventListener('click', () => modal.remove());
      mc.appendChild(closeBtn);
      modal.appendChild(mc);
      document.body.appendChild(modal);
    });
    document.getElementById('tb-reset')!.addEventListener('click', resetToBaseline);

    // Create panels
    panelEl = createThemePanel(state, handleUpdate);
    panelSlot.replaceWith(panelEl);

    a11yPanel = createA11yPanel(state);
    document.getElementById('tb-a11y-slot')!.replaceWith(a11yPanel.el);

    // Watch for grid theme switcher changes
    document.addEventListener('tbw-theme-change', () => {
      requestAnimationFrame(() => {
        // Clear inline overrides so computed styles reflect the new theme
        for (const category of Object.values(CSS_VARIABLES)) {
          for (const variable of category) {
            grid.style.removeProperty(variable.name);
          }
        }
        const computed = readComputedVariables(grid);
        state.values = { ...computed.light };
        state.darkValues = { ...computed.dark };
        state.baselineValues = { ...computed.light };
        state.baselineDarkValues = { ...computed.dark };
        applyStateToGrid(grid, state);
        if (panelEl) {
          const newPanel = createThemePanel(state, handleUpdate);
          panelEl.replaceWith(newPanel);
          panelEl = newPanel;
        }
        a11yPanel?.rebuild();
      });
    });
  });
  // #endregion
</script>

<style is:global>
  /* Theme Builder — ported from storybook-styles.css, adapted for Starlight tokens
   *
   * Token mapping (Storybook → Starlight):
   *   --sbdocs-bg          → var(--sl-color-bg)
   *   --sbdocs-table-header→ var(--sl-color-gray-6)
   *   --sb-border          → var(--sl-color-gray-5)
   *   --sbdocs-border      → var(--sl-color-gray-6)   (subtle border)
   *   --sbdocs-fg          → var(--sl-color-text)
   *   --sbdocs-heading     → var(--sl-color-white)
   *   --sbdocs-toc-link    → var(--sl-color-gray-3)
   *   --sbdocs-code-bg     → var(--sl-color-gray-6)
   *   --args-hover-bg      → var(--sl-color-gray-5)
   *   --args-input-bg      → var(--sl-color-gray-7)
   *   --args-prop-name     → var(--sl-color-accent)
   *   --sb-bg              → var(--sl-color-bg)
   *   --tbw-accent         → var(--sl-color-accent)
   */

  .theme-builder-container {
    height: 90vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .theme-builder-container:fullscreen {
    height: 100vh;
    background: var(--sl-color-bg, #fff);
  }

  .theme-builder-toolbar {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    align-items: center;
    flex-wrap: wrap;
  }

  .theme-builder-toolbar__label {
    font-weight: 500;
    color: var(--sl-color-text);
  }

  .theme-builder-btn {
    padding: 6px 12px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    cursor: pointer;
    font-size: 14px;
    transition: background 0.15s, border-color 0.15s;
  }

  .theme-builder-btn:hover {
    background: var(--sl-color-gray-5);
    border-color: var(--sl-color-accent);
  }

  .theme-builder-btn:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .theme-builder-btn--primary {
    background: var(--sl-color-accent);
    color: #fff;
    border-color: var(--sl-color-accent);
  }

  .theme-builder-btn--primary:hover {
    background: light-dark(#1d4ed8, #2563eb);
  }

  .theme-builder-btn--success {
    background: light-dark(#16a34a, #22c55e);
    color: #fff;
    border-color: transparent;
  }

  /* Main area with sidebar */
  .theme-builder-main {
    display: flex;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .theme-builder-grid-wrapper {
    flex: 1;
    min-width: 0;
    min-height: 0;
    padding: 16px;
    overflow: auto;
  }

  /* Modal overlay */
  .theme-builder-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
  }

  .theme-builder-modal__content {
    background: var(--sl-color-bg);
    border-radius: 8px;
    padding: 20px;
    max-width: 800px;
    max-height: 80vh;
    overflow: auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    border: 1px solid var(--sl-color-gray-5);
  }

  .theme-builder-modal__title {
    margin: 0 0 12px 0;
    color: var(--sl-color-white);
  }

  .theme-builder-modal__code {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text);
    padding: 16px;
    border-radius: 4px;
    overflow: auto;
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    border: 1px solid var(--sl-color-gray-5);
  }

  /* Collapsible Color Panel Sidebar */
  .theme-builder-panel {
    width: 380px;
    min-width: 380px;
    background: var(--sl-color-bg);
    border-left: 1px solid var(--sl-color-gray-5);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: width 0.2s, min-width 0.2s;
  }

  .theme-builder-panel--collapsed {
    width: 40px;
    min-width: 40px;
  }

  .theme-builder-panel__header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    flex-shrink: 0;
  }

  .theme-builder-panel__toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    padding: 4px;
    color: var(--sl-color-text);
    border-radius: 4px;
  }

  .theme-builder-panel__toggle:hover {
    background: var(--sl-color-gray-5);
  }

  .theme-builder-panel__title {
    font-weight: 600;
    font-size: 14px;
    color: var(--sl-color-white);
    flex: 1;
  }

  .theme-builder-panel--collapsed .theme-builder-panel__title,
  .theme-builder-panel--collapsed .theme-builder-panel__controls,
  .theme-builder-panel--collapsed .theme-builder-panel__content {
    display: none;
  }

  .theme-builder-panel__controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .theme-builder-panel__content {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }

  /* Dark mode toggle in panel header */
  .theme-builder-dark-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--sl-color-text);
  }

  .theme-builder-dark-toggle input { cursor: pointer; }

  /* Category sections */
  .theme-builder-category {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .theme-builder-category__header {
    display: flex;
    align-items: center;
    padding: 10px 12px;
    cursor: pointer;
    background: var(--sl-color-gray-6);
    user-select: none;
    gap: 8px;
  }

  .theme-builder-category__header:hover {
    background: var(--sl-color-gray-5);
  }

  .theme-builder-category__chevron {
    font-size: 10px;
    transition: transform 0.15s;
    color: var(--sl-color-gray-3);
  }

  .theme-builder-category--open .theme-builder-category__chevron {
    transform: rotate(90deg);
  }

  .theme-builder-category__name {
    font-weight: 500;
    font-size: 13px;
    color: var(--sl-color-white);
    flex: 1;
  }

  .theme-builder-category__count {
    font-size: 11px;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
    padding: 2px 6px;
    border-radius: 10px;
  }

  .theme-builder-category__items {
    display: none;
    padding: 8px 12px;
    background: var(--sl-color-bg);
  }

  .theme-builder-category--open .theme-builder-category__items {
    display: block;
  }

  /* Individual color row with side-by-side pickers */
  .theme-builder-color-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .theme-builder-color-row:last-child { border-bottom: none; }

  .theme-builder-color-row__label {
    flex: 1;
    min-width: 0;
    font-size: 12px;
    color: var(--sl-color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .theme-builder-color-row__label code {
    font-size: 11px;
    color: var(--sl-color-accent);
    background: var(--sl-color-gray-6);
    padding: 1px 4px;
    border-radius: 3px;
  }

  .theme-builder-color-row__pickers {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .theme-builder-color-picker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .theme-builder-color-picker__label {
    font-size: 9px;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.5px;
  }

  .theme-builder-color-picker__wrapper {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .theme-builder-color-picker__input {
    width: 36px;
    height: 24px;
    padding: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    cursor: pointer;
    background: none;
  }

  .theme-builder-color-picker__input:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .theme-builder-color-picker__input::-webkit-color-swatch-wrapper { padding: 2px; }
  .theme-builder-color-picker__input::-webkit-color-swatch { border-radius: 2px; border: none; }

  /* Transparent checkbox */
  .theme-builder-color-picker__transparent {
    display: flex;
    align-items: center;
    gap: 2px;
    font-size: 9px;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    user-select: none;
  }

  .theme-builder-color-picker__transparent input {
    width: 12px;
    height: 12px;
    margin: 0;
    cursor: pointer;
  }

  .theme-builder-color-picker__transparent-label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .theme-builder-color-picker--dark {
    opacity: 0.5;
    pointer-events: none;
  }

  .theme-builder-panel--dark-mode .theme-builder-color-picker--dark {
    opacity: 1;
    pointer-events: auto;
  }

  /* Non-color variable rows */
  .theme-builder-var-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .theme-builder-var-row:last-child { border-bottom: none; }

  .theme-builder-var-row__label {
    flex: 1;
    min-width: 0;
    font-size: 12px;
    color: var(--sl-color-text);
  }

  .theme-builder-var-row__label code {
    font-size: 11px;
    color: var(--sl-color-accent);
    background: var(--sl-color-gray-6);
    padding: 1px 4px;
    border-radius: 3px;
  }

  .theme-builder-var-row__input {
    width: 120px;
    padding: 4px 8px;
    font-size: 12px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    background: var(--sl-color-gray-7);
    color: var(--sl-color-text);
  }

  .theme-builder-var-row__select {
    width: 120px;
    padding: 4px 8px;
    font-size: 12px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    background: var(--sl-color-gray-7);
    color: var(--sl-color-text);
  }

  /* Accessibility section */
  /* ── Accessibility bottom bar ── */
  .theme-builder-a11y {
    border-top: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: max-height 0.2s ease;
  }

  .theme-builder-a11y__header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    flex-shrink: 0;
  }

  .theme-builder-a11y__toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    padding: 4px;
    color: var(--sl-color-text);
    border-radius: 4px;
    line-height: 1;
  }

  .theme-builder-a11y__toggle:hover {
    background: var(--sl-color-gray-5);
  }

  .theme-builder-a11y__title {
    font-weight: 600;
    font-size: 13px;
    color: var(--sl-color-white);
  }

  .theme-builder-a11y__legend {
    display: flex;
    gap: 6px;
    margin-left: auto;
    align-items: center;
  }

  .theme-builder-a11y--collapsed .theme-builder-a11y__content {
    display: none;
  }

  .theme-builder-a11y__content {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    align-items: stretch;
  }

  .theme-builder-a11y-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 10px;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 6px;
    background: light-dark(#f8f9fa, #1c2128);
  }

  .theme-builder-a11y-card__name {
    font-size: 11px;
    font-weight: 600;
    color: var(--sl-color-text);
    white-space: nowrap;
    min-width: 90px;
  }

  .theme-builder-a11y-card__badges {
    display: flex;
    gap: 6px;
  }

  .theme-builder-a11y-card__mode {
    display: flex;
    align-items: center;
    gap: 3px;
  }

  .theme-builder-a11y-card__mode-label {
    font-size: 11px;
  }

  .theme-builder-a11y-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-width: 48px;
    padding: 2px 6px;
    font-size: 10px;
    font-weight: 600;
    border-radius: 3px;
    white-space: nowrap;
  }

  .theme-builder-a11y-badge--aaa { background: light-dark(#d4edda, #1a4c2a); color: light-dark(#155724, #9fdfb4); }
  .theme-builder-a11y-badge--pass { background: light-dark(#d4edda, #1a3c2a); color: light-dark(#155724, #8fcea0); }
  .theme-builder-a11y-badge--large { background: light-dark(#fff3cd, #4a3c1a); color: light-dark(#856404, #e0c878); }
  .theme-builder-a11y-badge--fail { background: light-dark(#f8d7da, #4a1a1a); color: light-dark(#721c24, #e08888); }
  .theme-builder-a11y-badge--unknown { background: light-dark(#e2e3e5, #333); color: light-dark(#383d41, #999); }

  .theme-builder-a11y__legend .theme-builder-a11y-badge {
    pointer-events: none;
    font-size: 9px;
    min-width: unset;
    padding: 1px 5px;
  }
</style>
