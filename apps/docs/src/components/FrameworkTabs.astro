---
// FrameworkTabs.astro — Tabbed code examples for different frameworks.
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div class="framework-tabs not-content" id={`fw-tabs-${id}`}>
  <div role="tablist">
    <slot name="tabs" />
  </div>
  <slot />
</div>

<script>
  // Initialize all framework tab components
  document.querySelectorAll('.framework-tabs').forEach((container) => {
    const el = container as HTMLElement;
    // Prevent duplicate initialization under HMR or client-side navigation
    if (el.dataset.initialized === 'true') return;
    el.dataset.initialized = 'true';

    const tablist = el.querySelector('[role="tablist"]');
    const tabs = Array.from(tablist?.querySelectorAll('[role="tab"]') ?? []) as HTMLElement[];
    const panels = Array.from(el.querySelectorAll('[role="tabpanel"]')) as HTMLElement[];

    function activateTab(index: number, focus = false) {
      tabs.forEach((t, i) => {
        const selected = i === index;
        t.setAttribute('aria-selected', String(selected));
        t.setAttribute('tabindex', selected ? '0' : '-1');
      });
      panels.forEach((p, i) => {
        if (i === index) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
      if (focus) tabs[index]?.focus();
    }

    // Ensure initial state: first tab (or already-selected tab) is active
    const initialIndex = Math.max(0, tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true'));
    activateTab(initialIndex);

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activateTab(index));

      tab.addEventListener('keydown', (e: KeyboardEvent) => {
        let target = -1;
        if (e.key === 'ArrowRight') target = (index + 1) % tabs.length;
        else if (e.key === 'ArrowLeft') target = (index - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') target = 0;
        else if (e.key === 'End') target = tabs.length - 1;

        if (target >= 0) {
          e.preventDefault();
          activateTab(target, true);
        }
      });
    });
  });
</script>
