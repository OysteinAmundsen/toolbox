{
  "name": "@toolbox-web/components",
  "version": "0.2.9",
  "license": "MIT",
  "author": "Oystein Amundsen",
  "repository": {
    "type": "git",
    "url": "https://github.com/OysteinAmundsen/toolbox.git"
  },
  "homepage": "https://toolboxjs.com",
  "bugs": {
    "url": "https://github.com/OysteinAmundsen/toolbox/issues"
  },
  "scripts": {
    "nx": "nx",
    "start": "nx serve docs",
    "build": "nx run-many --target=build --exclude=docs --output-style=stream && bun run cem",
    "cem": "cd libs/grid && bunx cem analyze",
    "test": "nx run-many --target=test --exclude=demo-angular --output-style=stream --silent",
    "e2e": "nx run-many --target=e2e --parallel=1",
    "e2e:update": "nx e2e:update-snapshots e2e",
    "e2e:full": "bun run build && concurrently --kill-others --success first -n servers,e2e -c gray,magenta \"bun run demo:dist\" \"bunx wait-on http://localhost:4000 http://localhost:4300 http://localhost:4200 http://localhost:4100 -t 60000 && bun run e2e\"",
    "bench": "nx run-many --target=bench --output-style=stream",
    "demo": "concurrently --kill-others -n vanilla,react,angular,vue -c blue,green,yellow,cyan \"bun nx run demo-vanilla:serve\" \"bun nx run demo-react:serve\" \"bun nx run demo-angular:serve\" \"bun nx run demo-vue:serve\"",
    "demo:dist": "concurrently --kill-others -n vanilla,react,angular,vue -c blue,green,yellow,cyan \"bun nx run demo-vanilla:serve:dist\" \"bun nx run demo-react:serve:dist\" \"bun nx run demo-angular:serve:dist\" \"bun nx run demo-vue:serve:dist\"",
    "lint": "nx run-many --target=lint --parallel=6 --output-style=stream",
    "health": "bunx fallow",
    "coverage": "bun run test --coverage",
    "build:libs": "nx run-many --target=build --projects=grid,grid-angular,grid-react,grid-vue --output-style=stream",
    "build:watch": "bun tools/watch-libs.ts",
    "link:push": "bash -c 'for dir in dist/libs/*/; do [ -f \"${dir}package.json\" ] && (cd \"$dir\" && bunx yalc push --sig); done' || true",
    "dev": "bun run build:libs && bun run link:push && bun run build:watch",
    "update": "bun tools/update-deps.ts",
    "update:dry": "bun tools/update-deps.ts --dry-run",
    "update:full": "bun tools/update-deps.ts --e2e"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.7",
    "@angular/build": "~22.0.7",
    "@angular/core": "22.0.7",
    "@astrojs/cloudflare": "14.1.4",
    "@astrojs/mdx": "7.0.3",
    "@astrojs/starlight": "0.41.3",
    "@axe-core/playwright": "^4.11.3",
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@eslint/js": "9.39.5",
    "@nx/angular": "23.1.0",
    "@nx/devkit": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/eslint-plugin": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/playwright": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/vitest": "23.1.0",
    "@nx/web": "23.1.0",
    "@playwright/test": "1.61.1",
    "@swc-node/register": "1.12.1",
    "@swc/core": "1.15.46",
    "@swc/helpers": "0.5.23",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "astro": "7.1.3",
    "astro-mermaid": "2.1.0",
    "concurrently": "10.0.3",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-playwright": "2.10.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "happy-dom": "20.11.0",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "3.1.0",
    "mermaid": "11.16.0",
    "ng-packagr": "22.0.1",
    "nx": "23.1.0",
    "pagefind": "1.5.2",
    "prettier": "3.9.6",
    "react-router-dom": "7.18.1",
    "rollup-plugin-cleanup": "3.2.1",
    "rxjs": "7.8.2",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typedoc": "0.28.20",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-router": "5.2.0",
    "wait-on": "9.0.10"
  },
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "dependencies": {}
}
