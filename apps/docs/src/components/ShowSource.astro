---
/**
 * ShowSource.astro — Wraps a live demo and adds a collapsible "Show source" panel.
 *
 * At BUILD TIME, reads the demo's `.astro` file, extracts the `<script>` content,
 * cleans it into an idiomatic code example (removing DOM boilerplate), and renders
 * it with Shiki syntax highlighting via Astro's `<Code>` component.
 *
 * Usage in MDX:
 * ```mdx
 * <ShowSource file="demos/filtering/FilteringDefaultDemo.astro">
 *   <FilteringDefaultDemo />
 * </ShowSource>
 * ```
 */
import { Code } from 'astro-expressive-code/components';
import ts from 'typescript';
import FullscreenButton from './FullscreenButton.astro';

interface Props {
  /** Path to the demo .astro file, relative to src/components/ */
  file: string;
  /** Syntax highlighting language (default: typescript) */
  lang?: string;
}

const { file, lang = 'typescript' } = Astro.props;

// ---------------------------------------------------------------------------
// 1. Read demo file at build time
// ---------------------------------------------------------------------------
const demoFiles = import.meta.glob<string>('./demos/**/*.astro', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const rawContent = demoFiles[`./${file}`] ?? '';

// ---------------------------------------------------------------------------
// 2. Extract and clean the <script> content (AST-based)
// ---------------------------------------------------------------------------
//
// Strategy: parse the script as TypeScript, identify boilerplate to strip
// (the `const container = document.getElementById(...)` declaration, the
// `if (container) { ... }` guard wrapper, negative null guards, and the
// `container.addEventListener('control-change', ...)` blocks that wire up
// the DemoControls panel). Apply text edits to the *original* script text
// from end to start so we preserve the author's blank lines, comments, and
// indentation rather than round-tripping through the TS printer.
//
// Token-level edits collected during the AST walk:
//   - drop trailing `!` (NonNullExpression)
//   - drop `as <Type>` and `<Type>x` assertions
//   - normalize `queryGrid(selector, container)` calls — drop the container
//     argument; collapse selector to `'tbw-grid'` only when the demo has a
//     single grid (multi-grid demos keep their disambiguating selectors so
//     the displayed code remains runnable as-is)
//   - rewrite `container.querySelector(All)` to `document.querySelector(All)`

interface TextEdit {
  start: number;
  end: number;
  replacement: string;
}

function findContainerVar(sf: ts.SourceFile): string | null {
  for (const stmt of sf.statements) {
    if (!ts.isVariableStatement(stmt)) continue;
    if (stmt.declarationList.declarations.length !== 1) continue;
    const decl = stmt.declarationList.declarations[0];
    if (
      ts.isIdentifier(decl.name) &&
      decl.initializer &&
      ts.isCallExpression(decl.initializer) &&
      ts.isPropertyAccessExpression(decl.initializer.expression) &&
      ts.isIdentifier(decl.initializer.expression.expression) &&
      decl.initializer.expression.expression.text === 'document' &&
      decl.initializer.expression.name.text === 'getElementById'
    ) {
      return decl.name.text;
    }
  }
  return null;
}

function countQueryGridCalls(sf: ts.SourceFile): number {
  let count = 0;
  const visit = (node: ts.Node): void => {
    if (
      ts.isCallExpression(node) &&
      ts.isIdentifier(node.expression) &&
      node.expression.text === 'queryGrid'
    ) {
      count++;
    }
    ts.forEachChild(node, visit);
  };
  visit(sf);
  return count;
}

/** Statement-level skip predicates (consume the entire statement + trailing newline). */
function shouldSkipStatement(stmt: ts.Statement, containerVar: string | null): boolean {
  // Type-only imports
  if (ts.isImportDeclaration(stmt) && stmt.importClause?.isTypeOnly) return true;

  // `const containerVar = document.getElementById(...)`
  if (
    containerVar &&
    ts.isVariableStatement(stmt) &&
    stmt.declarationList.declarations.length === 1
  ) {
    const decl = stmt.declarationList.declarations[0];
    if (
      ts.isIdentifier(decl.name) &&
      decl.name.text === containerVar &&
      decl.initializer &&
      ts.isCallExpression(decl.initializer) &&
      ts.isPropertyAccessExpression(decl.initializer.expression) &&
      ts.isIdentifier(decl.initializer.expression.expression) &&
      decl.initializer.expression.expression.text === 'document'
    ) {
      return true;
    }
  }

  // `if (!ident) ...` negative guard one-liner
  if (
    ts.isIfStatement(stmt) &&
    ts.isPrefixUnaryExpression(stmt.expression) &&
    stmt.expression.operator === ts.SyntaxKind.ExclamationToken &&
    ts.isIdentifier(stmt.expression.operand)
  ) {
    return true;
  }

  // `containerVar.addEventListener('control-change', ...)`
  if (
    containerVar &&
    ts.isExpressionStatement(stmt) &&
    ts.isCallExpression(stmt.expression) &&
    ts.isPropertyAccessExpression(stmt.expression.expression) &&
    ts.isIdentifier(stmt.expression.expression.expression) &&
    stmt.expression.expression.expression.text === containerVar &&
    stmt.expression.expression.name.text === 'addEventListener' &&
    stmt.expression.arguments.length >= 1 &&
    ts.isStringLiteral(stmt.expression.arguments[0]) &&
    stmt.expression.arguments[0].text === 'control-change'
  ) {
    return true;
  }

  return false;
}

/**
 * Extend a node's range to swallow trailing whitespace + one newline so that
 * removing the statement doesn't leave a blank gap behind.
 */
function eatTrailingLine(text: string, end: number): number {
  let i = end;
  while (i < text.length && (text[i] === ' ' || text[i] === '\t')) i++;
  if (text[i] === '\r') i++;
  if (text[i] === '\n') i++;
  return i;
}

function eatLeadingIndent(text: string, start: number): number {
  let i = start;
  while (i > 0 && (text[i - 1] === ' ' || text[i - 1] === '\t')) i--;
  return i;
}

function collectEdits(sf: ts.SourceFile, code: string): TextEdit[] {
  const edits: TextEdit[] = [];
  const containerVar = findContainerVar(sf);
  const queryGridCount = countQueryGridCalls(sf);
  const normalizeSelector = queryGridCount <= 1;

  // ── Statement-level skips at the top level ──
  for (const stmt of sf.statements) {
    if (shouldSkipStatement(stmt, containerVar)) {
      edits.push({
        start: eatLeadingIndent(code, stmt.getStart(sf)),
        end: eatTrailingLine(code, stmt.getEnd()),
        replacement: '',
      });
    }
  }

  // ── Unwrap top-level `if (containerVar) { ... }` ──
  // Remove the `if (...) {` line and the matching `}`. Inner content keeps
  // its existing indentation; the global dedent at the end normalizes it.
  if (containerVar) {
    for (const stmt of sf.statements) {
      if (
        ts.isIfStatement(stmt) &&
        ts.isIdentifier(stmt.expression) &&
        stmt.expression.text === containerVar &&
        ts.isBlock(stmt.thenStatement)
      ) {
        const block = stmt.thenStatement;
        // Erase `if (container) {`
        const blockOpen = block.getStart(sf);
        edits.push({
          start: eatLeadingIndent(code, stmt.getStart(sf)),
          end: eatTrailingLine(code, blockOpen + 1),
          replacement: '',
        });
        // Erase the trailing `}`
        const blockEnd = block.getEnd();
        edits.push({
          start: eatLeadingIndent(code, blockEnd - 1),
          end: eatTrailingLine(code, blockEnd),
          replacement: '',
        });
        // Also drop statement-level skips that live INSIDE the block.
        for (const inner of block.statements) {
          if (shouldSkipStatement(inner, containerVar)) {
            edits.push({
              start: eatLeadingIndent(code, inner.getStart(sf)),
              end: eatTrailingLine(code, inner.getEnd()),
              replacement: '',
            });
          }
        }
        // Dedent each line inside the block by the indent introduced by the
        // wrapper. Without this, the outer dedent would only match the
        // imports' column-0 indent and leave the block body indented.
        const ifIndentMatch = code.slice(0, stmt.getStart(sf)).match(/(?:^|\n)([ \t]*)$/);
        const ifIndent = ifIndentMatch ? ifIndentMatch[1].length : 0;
        let innerMinIndent = Infinity;
        for (const inner of block.statements) {
          if (shouldSkipStatement(inner, containerVar)) continue;
          const innerStart = inner.getStart(sf);
          const innerLineStart = code.lastIndexOf('\n', innerStart - 1) + 1;
          const indent = innerStart - innerLineStart;
          if (indent < innerMinIndent) innerMinIndent = indent;
        }
        const stepSize = innerMinIndent === Infinity ? 0 : innerMinIndent - ifIndent;
        if (stepSize > 0) {
          // Emit a dedent edit per line in the block range.
          const blockBodyStart = blockOpen + 1;
          const blockBodyEnd = blockEnd - 1;
          let lineStart = blockBodyStart;
          while (lineStart < blockBodyEnd) {
            // Skip leading newline so lineStart points at the first column.
            if (code[lineStart] === '\n') lineStart++;
            else if (code[lineStart] === '\r' && code[lineStart + 1] === '\n') lineStart += 2;
            // Find current line's whitespace prefix length.
            let i = lineStart;
            while (i < blockBodyEnd && (code[i] === ' ' || code[i] === '\t')) i++;
            const stripEnd = Math.min(lineStart + stepSize, i);
            if (stripEnd > lineStart) {
              edits.push({ start: lineStart, end: stripEnd, replacement: '' });
            }
            // Advance to next line.
            const nextNl = code.indexOf('\n', lineStart);
            if (nextNl === -1 || nextNl >= blockBodyEnd) break;
            lineStart = nextNl + 1;
          }
        }
        break;
      }
    }
  }

  // ── Token-level transforms (walk the whole tree) ──
  const visit = (node: ts.Node): void => {
    // Strip trailing `!`
    if (ts.isNonNullExpression(node)) {
      edits.push({ start: node.expression.getEnd(), end: node.getEnd(), replacement: '' });
    }
    // Strip `expr as Type`
    if (ts.isAsExpression(node)) {
      edits.push({ start: node.expression.getEnd(), end: node.getEnd(), replacement: '' });
    }
    // Strip `<Type>expr` (legacy type assertion)
    if (ts.isTypeAssertionExpression(node)) {
      edits.push({ start: node.getStart(sf), end: node.expression.getStart(sf), replacement: '' });
    }
    // Strip `expr satisfies Type`
    if (ts.isSatisfiesExpression?.(node)) {
      edits.push({ start: node.expression.getEnd(), end: node.getEnd(), replacement: '' });
    }
    // queryGrid(selector, container) → queryGrid('tbw-grid') | queryGrid(selector)
    if (
      ts.isCallExpression(node) &&
      ts.isIdentifier(node.expression) &&
      node.expression.text === 'queryGrid' &&
      node.arguments.length >= 1
    ) {
      const args = node.arguments;
      const firstArg = args[0];
      const lastArg = args[args.length - 1];
      // Replace argument list contents (between the parens)
      const argsStart = firstArg.getStart(sf);
      const argsEnd = lastArg.getEnd();
      const replacement =
        normalizeSelector && ts.isStringLiteral(firstArg) ? `'tbw-grid'` : code.slice(argsStart, firstArg.getEnd());
      edits.push({ start: argsStart, end: argsEnd, replacement });
    }
    // containerVar.querySelector(All) → document.querySelector(All)
    if (
      containerVar &&
      ts.isPropertyAccessExpression(node) &&
      ts.isIdentifier(node.expression) &&
      node.expression.text === containerVar &&
      ts.isIdentifier(node.name) &&
      (node.name.text === 'querySelector' || node.name.text === 'querySelectorAll')
    ) {
      edits.push({ start: node.expression.getStart(sf), end: node.expression.getEnd(), replacement: 'document' });
    }
    ts.forEachChild(node, visit);
  };
  visit(sf);

  return edits;
}

function applyEdits(text: string, edits: TextEdit[]): string {
  // Sort by start ascending; resolve overlaps by keeping the outermost (earliest start, latest end).
  const sorted = [...edits].sort((a, b) => a.start - b.start || b.end - a.end);
  const merged: TextEdit[] = [];
  for (const e of sorted) {
    const prev = merged[merged.length - 1];
    if (prev && e.start < prev.end) {
      // Overlap: skip inner edit; the outer already covers it.
      if (e.end > prev.end) prev.end = e.end;
      continue;
    }
    merged.push({ ...e });
  }
  // Apply from end to start so offsets stay valid.
  let out = text;
  for (let i = merged.length - 1; i >= 0; i--) {
    const { start, end, replacement } = merged[i];
    out = out.slice(0, start) + replacement + out.slice(end);
  }
  return out;
}

function dedentMinimum(text: string): string {
  const lines = text.split('\n');
  const nonEmpty = lines.filter((l) => l.trim().length > 0);
  if (nonEmpty.length === 0) return text;
  const minIndent = Math.min(...nonEmpty.map((l) => l.search(/\S/)));
  if (minIndent <= 0) return text;
  return lines.map((l) => (l.trim() === '' ? '' : l.slice(minIndent))).join('\n');
}

function extractSource(content: string): string {
  const scriptMatch = content.match(/<script(?:\s[^>]*)?>(\r?\n)?([\s\S]*?)<\/script>/);
  if (!scriptMatch) return '';

  const code = scriptMatch[2];
  let sf: ts.SourceFile;
  try {
    sf = ts.createSourceFile('demo.ts', code, ts.ScriptTarget.Latest, /*setParents*/ true, ts.ScriptKind.TS);
  } catch {
    return code;
  }

  const edits = collectEdits(sf, code);
  const edited = applyEdits(code, edits);
  const dedented = dedentMinimum(edited);
  // Collapse runs of 3+ blank lines and trim leading/trailing whitespace.
  return dedented.replace(/\n{3,}/g, '\n\n').replace(/^\s*\n+/, '').trimEnd();
}

// ---------------------------------------------------------------------------
// 3. Extract meaningful HTML from the demo file
// ---------------------------------------------------------------------------
function extractHtml(content: string): string {
  const withoutFrontmatter = content.replace(/^---[\s\S]*?---\s*\n/, '');
  const htmlSection = withoutFrontmatter.match(/^([\s\S]*?)<script/);
  if (!htmlSection) return '';

  const html = htmlSection[1].trim();
  if (!html || !html.includes('<tbw-grid')) return '';

  // Extract the <tbw-grid>...</tbw-grid> block (handles child elements like <tbw-grid-column>)
  const gridMatch = html.match(/<tbw-grid[\s\S]*<\/tbw-grid>/);
  if (!gridMatch) return '';

  let result = gridMatch[0];

  // Strip demo-specific IDs
  result = result.replace(/\s+id="[^"]*"/g, '');

  // Re-indent from zero
  const lines = result.split('\n');
  const nonEmpty = lines.filter((l) => l.trim().length > 0);
  if (nonEmpty.length === 0) return '';
  const minIndent = Math.min(...nonEmpty.map((l) => l.search(/\S/)));

  return lines
    .map((l) => (l.trim() ? l.slice(minIndent) : ''))
    .join('\n')
    .trim();
}

const source = extractSource(rawContent);
const htmlSource = extractHtml(rawContent);

// Determine if the HTML is "simple" (a single self-closing <tbw-grid> tag, ≤2 lines)
// Simple HTML gets shown as a small stacked block above the JS; complex HTML gets its own tab.
const htmlLineCount = htmlSource ? htmlSource.split('\n').length : 0;
const isSimpleHtml = htmlSource && htmlLineCount <= 2 && !htmlSource.includes('<tbw-grid-column');
const complexHtml = htmlSource && !isSimpleHtml ? htmlSource : '';
const inlineHtml = isSimpleHtml ? htmlSource : '';
---

{source ? (
  <div class="show-source-wrapper not-content">
    <FullscreenButton target=".show-source-wrapper" label="Open demo in fullscreen" />
    <slot />
    <div class="demo-source-panel">
      <button class="demo-source-toggle" type="button" aria-expanded="false">
        <svg class="demo-source-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <polyline
            points="9 18 15 12 9 6"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span>Show source</span>
      </button>
      <div class="demo-source-content" hidden>
        {complexHtml ? (
          <div class="demo-source-tabs">
            <div class="demo-source-tab-bar" role="tablist">
              <button class="demo-source-tab active" role="tab" aria-selected="true" data-tab="js" type="button">JavaScript</button>
              <button class="demo-source-tab" role="tab" aria-selected="false" data-tab="html" type="button">HTML</button>
            </div>
            <div class="demo-source-tab-panel" data-panel="js">
              <div class="demo-source-code-wrap">
                <Code code={source} lang={lang} />
              </div>
            </div>
            <div class="demo-source-tab-panel" data-panel="html" hidden>
              <div class="demo-source-code-wrap">
                <Code code={complexHtml} lang="html" />
              </div>
            </div>
          </div>
        ) : (
          <div class="demo-source-stacked">
            {inlineHtml && (
              <div class="demo-source-code-wrap demo-source-html-inline">
                <Code code={inlineHtml} lang="html" title="HTML" />
              </div>
            )}
            <div class="demo-source-code-wrap">
              <Code code={source} lang={lang} />
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <slot />
)}

<script>
  document.addEventListener('click', (e) => {
    const toggle = (e.target as HTMLElement).closest('.demo-source-toggle');
    if (toggle) {
      const content = toggle.nextElementSibling as HTMLElement | null;
      if (!content) return;
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      content.hidden = expanded;
      const label = toggle.querySelector('span');
      if (label) label.textContent = expanded ? 'Show source' : 'Hide source';
      return;
    }

    // Tab switching for HTML/JS tabs
    const tab = (e.target as HTMLElement).closest('.demo-source-tab') as HTMLElement | null;
    if (tab) {
      const tabBar = tab.parentElement;
      if (!tabBar) return;
      const tabs = tabBar.querySelectorAll('.demo-source-tab');
      const wrapper = tabBar.closest('.demo-source-tabs');
      if (!wrapper) return;
      const panels = wrapper.querySelectorAll('.demo-source-tab-panel');
      const targetKey = tab.dataset.tab;

      tabs.forEach((t) => {
        t.classList.toggle('active', t === tab);
        t.setAttribute('aria-selected', String(t === tab));
      });
      panels.forEach((p: Element) => {
        (p as HTMLElement).hidden = (p as HTMLElement).dataset.panel !== targetKey;
      });
    }
  });
</script>

<style>
  /* --- Wrapper: connects demo and source panel visually --- */
  .show-source-wrapper {
    margin: 1.5rem 0;
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .show-source-wrapper > :global(.grid-demo),
  .show-source-wrapper > :global(.grid-playground) {
    margin: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  /* --- Source panel --- */
  .demo-source-panel {
    position: relative;
    border-top: none;
    background: var(--sl-color-gray-7);
  }

  .demo-source-content {
    border: 1px solid var(--sl-color-gray-5);
    border-top: 0;
    border-radius: 0 0 8px 8px;
    overflow: hidden;
  }

  /* --- Fullscreen button: top-right overlay on the demo --- */
  .show-source-wrapper > :global(.fullscreen-btn) {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.2s, color 0.15s, background 0.15s;
  }

  .show-source-wrapper:hover > :global(.fullscreen-btn),
  .show-source-wrapper:focus-within > :global(.fullscreen-btn),
  .show-source-wrapper > :global(.fullscreen-btn:focus-visible) {
    opacity: 1;
  }

  /* Always visible when in fullscreen */
  .show-source-wrapper > :global(.fullscreen-btn.fullscreen-btn--active) {
    opacity: 1;
  }

  /* --- Fullscreen mode --- */
  .show-source-wrapper:fullscreen {
    background: var(--sl-color-bg, #fff);
    padding: 2rem;
    overflow: auto;
    display: flex;
    flex-direction: column;
  }

  .show-source-wrapper:fullscreen > :global(.grid-demo) tbw-grid,
  .show-source-wrapper:fullscreen > :global(.grid-playground) tbw-grid {
    height: 80vh;
  }

  .show-source-wrapper:fullscreen > :global(.grid-demo),
  .show-source-wrapper:fullscreen > :global(.grid-playground) {
    flex: 1;
    border-radius: 8px;
  }

  /* --- Toggle button --- */
  .demo-source-toggle {
    position: absolute;
    top: 0px;
    right: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    transition: color 0.15s;
  }

  .demo-source-toggle:hover {
    color: var(--sl-color-text);
  }

  .demo-source-chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .demo-source-toggle[aria-expanded='true'] .demo-source-chevron {
    transform: rotate(90deg);
  }

  /* --- Code block --- */
  .demo-source-code-wrap {
    position: relative;
  }

  .demo-source-code-wrap :global(pre) {
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
    max-height: 500px;
    padding: .5rem;
  }

  /* --- Stacked HTML + JS blocks --- */
  .demo-source-stacked {
    display: flex;
    flex-direction: column;
  }

  .demo-source-html-inline {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .demo-source-html-inline :global(.expressive-code) {
    margin: 0 !important;
  }

  /* --- Tab bar for HTML/JS --- */
  .demo-source-tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
  }

  .demo-source-tab {
    padding: 0.4rem 1rem;
    border: none;
    background: transparent;
    color: var(--sl-color-gray-3);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .demo-source-tab:hover {
    color: var(--sl-color-text);
  }

  .demo-source-tab.active {
    color: var(--sl-color-text);
    border-bottom-color: var(--sl-color-text-accent);
  }


</style>
