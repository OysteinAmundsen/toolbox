/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/*.log
*.log
/typings
**/.angular

# Astro generated types/cache
.astro/

# Wrangler local state
.wrangler/

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md


storybook-static
vite.config.*.timestamp*
vitest.config.*.timestamp*
test-output

# Playwright E2E test artifacts
e2e/test-results/
e2e/snapshots/
playwright-report/

# Generated API documentation (regenerate with `nx typedoc grid`)
# Raw TypeDoc markdown output - always regenerated
**/api-generated/
# Generated TypeDoc MDX pages (core API + plugin doc folders + adapter APIs)
**/api/
**/Classes/
**/Interfaces/
**/Functions/
**/Types/
**/Enums/

# RFC and analysis documents (local only)
**/RFC/*
ANALYSIS-*.md
tsconfig.tsbuildinfo
.vscode/tasks.json
scripts/analyze-trace.mjs
test-results/.last-run.json
