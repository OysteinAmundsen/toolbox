{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "features/clipboard/src/index.ts",
    "features/column-virtualization/src/index.ts",
    "features/context-menu/src/index.ts",
    "features/editing/src/index.ts",
    "features/export/src/index.ts",
    "features/filtering/src/index.ts",
    "features/grouping-columns/src/index.ts",
    "features/grouping-rows/src/index.ts",
    "features/master-detail/src/index.ts",
    "features/multi-sort/src/index.ts",
    "features/pinned-columns/src/index.ts",
    "features/pinned-rows/src/index.ts",
    "features/pivot/src/index.ts",
    "features/print/src/index.ts",
    "features/reorder-columns/src/index.ts",
    "features/reorder-rows/src/index.ts",
    "features/responsive/src/index.ts",
    "features/row-drag-drop/src/index.ts",
    "features/selection/src/index.ts",
    "features/server-side/src/index.ts",
    "features/tooltip/src/index.ts",
    "features/tree/src/index.ts",
    "features/undo-redo/src/index.ts",
    "features/visibility/src/index.ts"
  ],
  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.typedoc.json",
  "json": "docs/api-generated/api.json",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "excludeNotDocumented": false,
  "excludeExternals": true,
  "externalPattern": ["**/node_modules/**"],
  "sort": ["source-order"],
  "categoryOrder": ["Directives", "Features", "Types", "Utilities", "*"],
  "externalSymbolLinkMappings": {
    "@toolbox-web/grid": {
      "ColumnEditorContext": "https://toolboxjs.com/grid/api/core/Interfaces/ColumnEditorContext/",
      "DataGridElement": "https://toolboxjs.com/grid/api/core/Classes/DataGridElement/",
      "DataGridElement.sort": "https://toolboxjs.com/grid/api/core/Classes/DataGridElement/#sort",
      "DataGridElement.sortModel": "https://toolboxjs.com/grid/api/core/Classes/DataGridElement/#sortmodel",
      "BaseColumnConfig.sortComparator": "https://toolboxjs.com/grid/api/core/Interfaces/BaseColumnConfig/#sortcomparator"
    }
  },
  "blockTags": [
    "@category",
    "@default",
    "@defaultValue",
    "@deprecated",
    "@example",
    "@fires",
    "@internal",
    "@param",
    "@remarks",
    "@requires",
    "@returns",
    "@see",
    "@since",
    "@template",
    "@throws",
    "@typeParam"
  ]
}
