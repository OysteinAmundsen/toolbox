{
  "name": "grid-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/grid-react/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:grid"
  ],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "dependsOn": [
        {
          "projects": [
            "grid"
          ],
          "target": "build"
        }
      ],
      "options": {
        "outputPath": "dist/libs/grid-react",
        "emptyOutDir": true
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "bundle-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "bun run tools/check-bundle-budget.ts dist/libs/grid-react \"[{\\\"path\\\":\\\"index.js\\\",\\\"maxSize\\\":51200,\\\"maxGzip\\\":15360,\\\"warnGzip\\\":12288}]\""
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "{projectRoot}/../../coverage/libs/grid-react"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/grid-react/**/*.ts",
          "libs/grid-react/**/*.tsx"
        ]
      }
    },
    "typedoc": {
      "command": "bunx typedoc --options typedoc.json && bun run scripts/typedoc-to-mdx.ts",
      "dependsOn": [
        "grid:build"
      ],
      "options": {
        "cwd": "libs/grid-react"
      },
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/src/**/*.tsx",
        "{projectRoot}/typedoc.json",
        "{projectRoot}/scripts/typedoc-to-mdx.ts"
      ],
      "outputs": [
        "{projectRoot}/docs/api-generated",
        "{workspaceRoot}/apps/docs/src/content/docs/grid/react/api"
      ]
    }
  }
}
