---
/**
 * Audience — gate a block of MDX content to a single consumer.
 *
 * Two directions, set via the required `only` prop:
 * - `only="human"`  → rendered on the HTML docs site, STRIPPED from the agent
 *   markdown corpus (`llms-full.txt` and the per-page `.md` companions). Use for
 *   sales/marketing prose, motivational asides, and other copy that would only
 *   dilute the implementation guidance an agent ingests.
 * - `only="agent"`  → NOT rendered on the HTML site, KEPT (tags unwrapped) in the
 *   agent markdown corpus. Use for front-loaded steering directives, extra
 *   gotchas, and copy-paste recipes that help a code-generating agent but would
 *   be noise for a human reading the rendered page.
 *
 * The HTML behaviour lives here (the component simply renders or omits its
 * slot). The agent-corpus behaviour lives in the pure `mdxToAgentMarkdown`
 * transform (`_llm-markdown.ts`), which strips/unwraps `<Audience>` regions in
 * the raw MDX BEFORE rendering — the two paths are deliberately independent so
 * each output sees exactly the content meant for it.
 *
 * Authoring note: leave a blank line after the opening tag and before the
 * closing tag so MDX parses the children as Markdown blocks, e.g.
 *
 *   <Audience only="agent">
 *
 *   _## Agent-only heading
 *
 *   prose…
 *
 *   </Audience>
 *
 * Use the `_##` sentinel (an underscore-prefixed heading) for section breaks
 * inside an `only="agent"` block — never a real `##`. Starlight harvests every
 * real heading into the human page's table-of-contents at compile time, BEFORE
 * this component conditionally drops the slot, so a real `##` here leaks a
 * phantom TOC link to content the human reader cannot see. `_#…` is not a valid
 * CommonMark heading, so the human build ignores it; the agent-markdown
 * transform (`_llm-markdown.ts`, step 1b) strips the leading `_` to restore a
 * true heading agents can navigate by.
 */
interface Props {
  /** Which consumer the wrapped content is for. */
  only: 'human' | 'agent';
}

const { only } = Astro.props;
// Only `human` blocks render on the site; `agent` blocks exist purely for the
// generated markdown corpus and produce no DOM here.
const renderOnSite = only === 'human';
---

{renderOnSite && <slot />}
