{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@toolbox-web/grid": ["../../libs/grid/src/index.ts"],
      "@toolbox-web/grid/*": ["../../libs/grid/src/*"],
      "@demo/shared/employee-management/styles": ["../shared/employee-management/styles.ts"],
      "@demo/shared/employee-management": ["../shared/employee-management/index.ts"],
      "@demo/shared/booking-logs": ["../shared/booking-logs/index.ts"],
      "@demo/shared/calendar": ["../shared/calendar/index.ts"]
    },
    "noUncheckedSideEffectImports": false,
    "types": ["*"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "../shared/employee-management/**/*.ts",
    "../shared/booking-logs/**/*.ts",
    "../shared/calendar/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"],
  "references": []
}
