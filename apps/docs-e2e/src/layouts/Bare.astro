---
/**
 * Bare HTML layout for isolated demo testing.
 * No Starlight chrome, no navigation — just a clean HTML shell.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Demo Test</title>
    <style>
      /* Provide minimal Starlight-like CSS variables that demos reference */
      :root {
        color-scheme: light dark;
        --sl-color-gray-1: #444;
        --sl-color-gray-2: #666;
        --sl-color-gray-3: #888;
        --sl-color-gray-4: #aaa;
        --sl-color-gray-5: #ddd;
        --sl-color-gray-6: #f5f5f5;
        --sl-color-accent: #0969da;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --sl-color-gray-1: #ccc;
          --sl-color-gray-2: #aaa;
          --sl-color-gray-3: #888;
          --sl-color-gray-4: #666;
          --sl-color-gray-5: #333;
          --sl-color-gray-6: #1a1a1a;
          --sl-color-accent: #58a6ff;
        }
      }
      body { margin: 0; padding: 16px; font-family: system-ui, sans-serif; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
