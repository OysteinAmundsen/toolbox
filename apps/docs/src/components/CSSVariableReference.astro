---
/**
 * CSSVariableReference.astro — Live CSS variable reference table for @toolbox-web/grid
 *
 * Ported from VariableReference.stories.ts. Shows all CSS variables with their
 * current computed values, auto-updating on theme / color-scheme changes.
 */
---

<div class="css-var-reference not-content" id="css-var-reference">
  <p class="css-var-reference__intro">
    The table below shows all CSS custom properties with their <strong>current computed values</strong> in this page's context.
    Switch between light and dark mode to see how values change.
  </p>
  <tbw-grid id="css-var-probe" style="position:absolute; visibility:hidden; pointer-events:none; height:0; overflow:hidden;"></tbw-grid>
  <div id="css-var-categories"></div>
</div>

<script>
  import '@toolbox-web/grid';

  // #region CSS Variable Definitions
  import { CSS_VARIABLES, type CSSVariableDefinition } from '../data/css-variable-registry.js';
  // #endregion

  // #region Build Reference Tables
  const probe = document.getElementById('css-var-probe') as HTMLElement;
  const container = document.getElementById('css-var-categories')!;

  interface ValueCell {
    td: HTMLElement;
    swatch: HTMLElement | null;
    def: CSSVariableDefinition;
  }

  const valueCells: ValueCell[] = [];

  function rgbToHex(rgb: string): string {
    // Handle rgb(r, g, b) / rgba(r, g, b, a)
    const m = rgb.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
    if (m) {
      const hex = `#${[m[1], m[2], m[3]].map(x => parseInt(x).toString(16).padStart(2, '0')).join('')}`;
      if (m[4] !== undefined && parseFloat(m[4]) < 1) {
        const alpha = Math.round(parseFloat(m[4]) * 255).toString(16).padStart(2, '0');
        return `${hex}${alpha}`;
      }
      return hex;
    }
    // Handle color(srgb r g b) — values are 0..1 floats
    const s = rgb.match(/color\(srgb\s+([\d.]+)\s+([\d.]+)\s+([\d.]+)/);
    if (s) return `#${[s[1], s[2], s[3]].map(x => Math.round(parseFloat(x) * 255).toString(16).padStart(2, '0')).join('')}`;
    return rgb;
  }

  function readValue(def: CSSVariableDefinition, swatchEl?: HTMLElement | null): string {
    const computedStyle = getComputedStyle(probe);
    const computedValue = computedStyle.getPropertyValue(def.name).trim() || def.defaultValue;

    if (def.type === 'color' && swatchEl) {
      // Apply the CSS function to the swatch — browser resolves light-dark(), etc.
      swatchEl.style.background = computedValue;
      const resolvedColor = getComputedStyle(swatchEl).backgroundColor;
      return rgbToHex(resolvedColor) || def.defaultValue;
    }
    return computedValue;
  }

  for (const [category, variables] of Object.entries(CSS_VARIABLES)) {
    const section = document.createElement('div');
    section.className = 'css-var-section';

    const h = document.createElement('h3');
    h.className = 'css-var-section__title';
    h.textContent = category;
    section.appendChild(h);

    const table = document.createElement('table');
    table.className = 'css-var-table';
    table.innerHTML = `<thead><tr><th>Variable</th><th>Current Value</th><th>Description</th></tr></thead>`;
    const tbody = document.createElement('tbody');

    for (const def of variables) {
      const tr = document.createElement('tr');

      const tdName = document.createElement('td');
      tdName.innerHTML = `<code class="css-var-table__var-name">${def.name}</code>`;
      tr.appendChild(tdName);

      const tdValue = document.createElement('td');
      tdValue.className = 'css-var-table__default';

      let swatch: HTMLElement | null = null;
      if (def.type === 'color') {
        swatch = document.createElement('span');
        swatch.className = 'css-var-swatch';
        tdValue.appendChild(swatch);
      }
      const valueText = document.createTextNode(def.defaultValue);
      tdValue.appendChild(valueText);
      tr.appendChild(tdValue);

      const tdDesc = document.createElement('td');
      tdDesc.textContent = def.description;
      tr.appendChild(tdDesc);

      tbody.appendChild(tr);
      valueCells.push({ td: tdValue, swatch, def });
    }

    table.appendChild(tbody);
    section.appendChild(table);
    container.appendChild(section);
  }

  // #endregion

  // #region Auto-Update
  // Populate values after DOM attachment
  function updateValues(): void {
    for (const cell of valueCells) {
      const val = readValue(cell.def, cell.swatch);
      const textNode = cell.td.lastChild;
      if (textNode && textNode.nodeType === Node.TEXT_NODE) {
        textNode.textContent = val;
      }
    }
  }
  requestAnimationFrame(updateValues);

  // Watch for theme changes (Starlight adds data-theme to <html>)
  const observer = new MutationObserver(updateValues);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class', 'style'] });

  // Watch for grid theme switcher changes
  document.addEventListener('tbw-theme-change', () => requestAnimationFrame(updateValues));

  // Watch for color-scheme media changes
  const mql = window.matchMedia('(prefers-color-scheme: dark)');
  mql.addEventListener('change', updateValues);
  // #endregion
</script>

<style is:global>
  /* CSS Variable Reference — matches old Storybook VariableReference.stories.ts styling
   * Token mapping: Storybook → Starlight
   *   --sbdocs-fg          → var(--sl-color-text)
   *   --sbdocs-heading     → var(--sl-color-white)
   *   --sbdocs-toc-link    → var(--sl-color-gray-3)
   *   --sbdocs-table-header→ var(--sl-color-gray-6)
   *   --sb-border          → var(--sl-color-gray-5)
   *   --sbdocs-border      → var(--sl-color-gray-6)
   *   --sbdocs-bg          → var(--sl-color-bg)
   *   --sbdocs-code-bg     → var(--sl-color-gray-6)
   *   --args-prop-name     → var(--sl-color-accent)
   */

  .css-var-reference {
    padding: 24px;
    max-width: 1000px;
    color: var(--sl-color-text);
  }

  .css-var-reference__intro {
    color: var(--sl-color-gray-3);
    margin-bottom: 16px;
  }

  .css-var-section {
    margin-bottom: 32px;
  }

  .css-var-section__title {
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .css-var-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .css-var-table th {
    padding: 8px 12px;
    text-align: left;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-text);
  }

  .css-var-table td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--sl-color-gray-6);
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    vertical-align: middle;
  }

  .css-var-table__var-name {
    font-family: monospace;
    color: var(--sl-color-accent);
    background: var(--sl-color-gray-6);
    padding: 2px 4px;
    border-radius: 3px;
  }

  .css-var-table__default {
    font-family: monospace;
  }

  .css-var-swatch {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 1px solid var(--sl-color-gray-5);
    vertical-align: middle;
    margin-right: 8px;
    border-radius: 2px;
  }
</style>
