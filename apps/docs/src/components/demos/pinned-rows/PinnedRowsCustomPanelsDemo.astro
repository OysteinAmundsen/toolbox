---
// PinnedRowsCustomPanelsDemo.astro
---
<div class="grid-demo not-content" id="pinned-rows-custom-panels-demo">
  <tbw-grid style="height: 400px;"></tbw-grid>
</div>

<script>
import '@toolbox-web/grid';
import { queryGrid } from '@toolbox-web/grid';

import '@toolbox-web/grid/features/pinned-rows';
import {
rowCountPanel,
type PinnedRowSlot,
} from '@toolbox-web/grid/plugins/pinned-rows';

const container = document.getElementById('pinned-rows-custom-panels-demo');
if (container) {
  // Generate sample data
  const generateData = (count: number) => {
    const names = ['Widget', 'Gadget', 'Gizmo', 'Doohickey', 'Thingamabob'];
    return Array.from({ length: count }, (_, i) => ({
      id: i + 1,
      name: names[i % names.length],
      quantity: Math.floor(Math.random() * 100) + 10,
      price: Math.round((Math.random() * 50 + 5) * 100) / 100,
    }));
  };
  const columns = [
    { field: 'id', header: 'ID', type: 'number' },
    { field: 'name', header: 'Name' },
    { field: 'quantity', header: 'Qty', type: 'number' },
    { field: 'price', header: 'Price', type: 'number' },
  ];

  const grid = queryGrid('tbw-grid', container)!;

  const slots: PinnedRowSlot[] = [
    // Built-in: row count, left zone, always visible
    { id: 'count', position: 'bottom', render: rowCountPanel() },
    // Custom panel slot with two zones in the same row
    {
      id: 'info',
      position: 'bottom',
      render: [
        {
          zone: 'center',
          render: () => {
            const el = document.createElement('span');
            el.className = 'tbw-status-panel';
            el.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
            return el;
          },
        },
        {
          zone: 'right',
          render: (ctx) => {
            const rows = ctx.rows as Array<{ quantity: number; price: number }>;
            const total = rows.reduce(
              (sum, row) => sum + (row.quantity || 0) * (row.price || 0),
              0,
            );
            const el = document.createElement('strong');
            el.className = 'tbw-status-panel';
            el.textContent = `Value: $${total.toFixed(2)}`;
            return el;
          },
        },
      ],
    },
  ];

  grid.gridConfig = {
    columns,
    features: {
      pinnedRows: { slots },
    },
  };
  grid.rows = generateData(50);
}
</script>
