---
// PerformanceComparisonDemo.astro — Head-to-head benchmark: Toolbox Grid vs
// a selectable competitor (AG Grid Community, Tabulator, …).
// Each competitor is a small adapter under ./competitors/. Results are cached
// per competitor for the lifetime of the page so switching the dropdown does
// not throw away a previous run.
---
<div class="perf-compare-wrapper not-content">
  <div class="perf-compare-bar">
    <div class="perf-compare-bar-left">
      <button id="compare-run" class="perf-compare-btn">Run Comparison</button>
      <label class="perf-compare-select-wrap">
        Compare against
        <select id="compare-competitor" class="perf-compare-select"></select>
      </label>
      <span id="compare-status">Ready</span>
    </div>
    <div class="perf-compare-bar-right">
      <span id="compare-versions" style="font-size:12px;opacity:0.7;"></span>
    </div>
  </div>

  <div id="compare-progress" class="perf-compare-progress" style="display:none;">
    <div id="compare-progress-bar" class="perf-compare-progress-fill"></div>
  </div>

  <details id="compare-config-details" class="perf-compare-config">
    <summary>Show Grid Configurations</summary>
    <div class="perf-compare-config-panels">
      <div class="perf-compare-config-panel">
        <h4 id="compare-config-tbw-title">Toolbox Grid</h4>
        <pre id="compare-config-tbw"><code>// Configuration displayed here</code></pre>
      </div>
      <div class="perf-compare-config-panel">
        <h4 id="compare-config-other-title">Competitor</h4>
        <pre id="compare-config-other"><code>// Configuration displayed here</code></pre>
      </div>
    </div>
  </details>

  <div id="compare-grid-area" class="perf-compare-grid-area">
    <p style="text-align:center;opacity:0.6;padding:40px 0;">Grid will render here during benchmarks (one at a time)</p>
  </div>

  <div id="compare-results" class="perf-compare-results">
    <p>Pick a competitor and click <strong>Run Comparison</strong> to benchmark both grids at increasing data sizes.</p>
    <p style="opacity:0.7;font-size:12px;">Scale points: 5K → 100K → 500K → 1M rows × 10 columns. Tests: init render, scroll, sort, filter, data replacement, single-row update, column resize, scroll-to-end, memory. Each metric runs 5× per scale point (trimmed mean). Each grid runs alone with a cooldown between them.</p>
  </div>
</div>

<script>
  import {
    ALL_METRICS,
    MEMORY_METRIC,
    baselineAdapter,
    competitors,
    getCompetitor,
  } from './competitors/index.js';
  import type { CompetitorAdapter, MetricName, ScaleResult } from './competitors/index.js';
  import {
    COL_COUNT,
    ITERATIONS,
    NOISE_FLOOR_MS,
    SCALE_POINTS,
    cooldown,
    formatMetric,
    formatRowCount,
    hasMemoryApi,
  } from './competitors/shared.js';

  // #region Config + Cache
  const COLOR_BASELINE = baselineAdapter.color;
  const COLOR_WIN = '#4ade80';
  const COLOR_LOSE = '#f87171';
  const COLOR_TIE = '#94a3b8';

  /** Cached benchmark runs keyed by `competitor.id`. */
  const cache = new Map<string, ScaleResult[]>();

  let currentCompetitor: CompetitorAdapter = competitors[0];
  // #endregion

  // #region DOM References
  const runBtn = document.getElementById('compare-run') as HTMLButtonElement;
  const competitorSelect = document.getElementById('compare-competitor') as HTMLSelectElement;
  const statusEl = document.getElementById('compare-status')!;
  const resultsEl = document.getElementById('compare-results')!;
  const gridArea = document.getElementById('compare-grid-area')!;
  const progressContainer = document.getElementById('compare-progress')!;
  const progressBar = document.getElementById('compare-progress-bar')!;
  const versionsEl = document.getElementById('compare-versions')!;
  const tbwConfigEl = document.getElementById('compare-config-tbw')!;
  const tbwConfigTitleEl = document.getElementById('compare-config-tbw-title')!;
  const otherConfigEl = document.getElementById('compare-config-other')!;
  const otherConfigTitleEl = document.getElementById('compare-config-other-title')!;
  // #endregion

  // #region Initial UI Population
  for (const c of competitors) {
    const opt = document.createElement('option');
    opt.value = c.id;
    opt.textContent = c.name;
    competitorSelect.appendChild(opt);
  }
  competitorSelect.value = currentCompetitor.id;

  tbwConfigTitleEl.textContent = baselineAdapter.name;
  tbwConfigTitleEl.style.color = baselineAdapter.color;
  tbwConfigEl.textContent = baselineAdapter.configCode;

  function applyCompetitorToUi(competitor: CompetitorAdapter) {
    otherConfigTitleEl.textContent = competitor.name;
    otherConfigTitleEl.style.color = competitor.color;
    otherConfigEl.textContent = competitor.configCode;
    versionsEl.textContent = competitor.version
      ? `${competitor.name} v${competitor.version}`
      : competitor.description ?? '';
    const cached = cache.get(competitor.id);
    if (cached) {
      resultsEl.innerHTML = renderScaleTable(cached, competitor, true);
      statusEl.textContent = `Cached — ${competitor.name}`;
    } else {
      resultsEl.innerHTML = `<p>Click <strong>Run Comparison</strong> to benchmark <strong style="color:${competitor.color}">${competitor.name}</strong> against ${baselineAdapter.name}.</p>
        <p style="opacity:0.7;font-size:12px;">Scale points: ${SCALE_POINTS.map(formatRowCount).join(' → ')} rows × ${COL_COUNT} columns. Each grid is loaded from CDN on first run. Cached results survive switching the dropdown.</p>`;
      statusEl.textContent = 'Ready';
    }
  }
  applyCompetitorToUi(currentCompetitor);

  competitorSelect.addEventListener('change', () => {
    currentCompetitor = getCompetitor(competitorSelect.value);
    applyCompetitorToUi(currentCompetitor);
  });
  // #endregion

  // #region Result Rendering
  function formatDelta(winner: number, loser: number): string {
    if (loser === 0 || winner === 0) return '';
    const ratio = loser / winner;
    if (ratio < 1.05) return '';
    return `${ratio.toFixed(1)}×`;
  }

  function renderScaleTable(
    allResults: ScaleResult[],
    competitor: CompetitorAdapter,
    done: boolean,
  ): string {
    const activeMetrics = ALL_METRICS.filter((metric) =>
      allResults.some((r) => r.tbw.has(metric) || r.competitor.has(metric)),
    );

    const competitorColor = competitor.color;

    let html = `<div class="perf-legend">
      <span class="perf-legend-item"><span class="perf-legend-swatch" style="background:${COLOR_BASELINE}"></span> ${baselineAdapter.name}</span>
      <span class="perf-legend-item"><span class="perf-legend-swatch" style="background:${competitorColor}"></span> ${competitor.name}</span>
      <span class="perf-legend-hint">Lower is better · <span style="color:${COLOR_WIN}">green</span> = winner · <span style="color:${COLOR_TIE}">gray</span> = within noise</span>
    </div>`;
    html += '<div class="perf-card-grid">';

    for (const metric of activeMetrics) {
      let maxVal = 0;
      for (const r of allResults) {
        maxVal = Math.max(maxVal, r.tbw.get(metric) ?? 0, r.competitor.get(metric) ?? 0);
      }
      if (maxVal === 0) maxVal = 1;

      const isMemory = metric === MEMORY_METRIC;

      // Per-card geometric mean across scale points.
      const cardRatios: number[] = [];
      for (const r of allResults) {
        const t = r.tbw.get(metric);
        const c = r.competitor.get(metric);
        if (t !== undefined && c !== undefined && t > 0 && c > 0) {
          const isTieCheck = !isMemory && t < NOISE_FLOOR_MS && c < NOISE_FLOOR_MS;
          if (!isTieCheck) cardRatios.push(c / t);
        }
      }
      const cardGeoMean = cardRatios.length > 0
        ? Math.pow(cardRatios.reduce((p, r) => p * r, 1), 1 / cardRatios.length)
        : 1;
      const cardWinner = cardGeoMean >= 1 ? 'BASE' : 'OTHER';
      const cardSpeedup = cardGeoMean >= 1 ? cardGeoMean : 1 / cardGeoMean;
      const winnerName = cardWinner === 'BASE' ? baselineAdapter.shortLabel : competitor.shortLabel;
      const winnerColor = cardWinner === 'BASE' ? COLOR_BASELINE : competitorColor;
      const cardLabel = isMemory ? `${cardSpeedup.toFixed(1)}× smaller` : `${cardSpeedup.toFixed(1)}× faster`;
      const cardSubtitle = done && cardRatios.length > 0 && cardSpeedup >= 1.05
        ? `<span class="perf-card-subtitle" style="color:${winnerColor}">${winnerName} ${cardLabel}</span>`
        : '';

      html += `<div class="perf-card">
        <div class="perf-card-title">${metric}${cardSubtitle}</div>`;

      for (const r of allResults) {
        const tbw = r.tbw.get(metric);
        const other = r.competitor.get(metric);
        const tbwDone = tbw !== undefined;
        const otherDone = other !== undefined;
        const bothDone = tbwDone && otherDone;

        const isTie = !isMemory && bothDone && (tbw!) < NOISE_FLOOR_MS && (other!) < NOISE_FLOOR_MS;
        const tbwWins = !isTie && bothDone && (tbw!) <= (other!);
        const otherWins = !isTie && bothDone && (other!) < (tbw!);

        const tbwPct = tbwDone ? Math.max(3, ((tbw!) / maxVal) * 100) : 0;
        const otherPct = otherDone ? Math.max(3, ((other!) / maxVal) * 100) : 0;
        const tbwLabel = tbwDone ? formatMetric(metric, tbw!) : '…';
        const otherLabel = otherDone ? formatMetric(metric, other!) : '…';

        const tbwValColor = !bothDone ? '#888' : isTie ? COLOR_TIE : tbwWins ? COLOR_WIN : COLOR_LOSE;
        const otherValColor = !bothDone ? '#888' : isTie ? COLOR_TIE : otherWins ? COLOR_WIN : COLOR_LOSE;

        const tbwDelta = tbwWins ? formatDelta(tbw!, other!) : '';
        const otherDelta = otherWins ? formatDelta(other!, tbw!) : '';
        const rowClass = tbwWins
          ? 'perf-row perf-row-baseline-wins'
          : otherWins
            ? 'perf-row perf-row-other-wins'
            : 'perf-row';

        html += `
          <div class="${rowClass}">
            <div class="perf-row-label">${formatRowCount(r.rowCount)}</div>
            <div class="perf-row-bars">
              <div class="perf-bar-row perf-bar-row-top">
                <span class="perf-bar-name" style="color:${COLOR_BASELINE}">${baselineAdapter.shortLabel}</span>
                <div class="perf-bar-track">
                  <div class="perf-bar-fill" style="width:${tbwPct}%;background:${COLOR_BASELINE};"></div>
                </div>
                <span class="perf-bar-value" style="color:${tbwValColor}">${tbwLabel}${tbwDelta ? ` <span class="perf-delta">${tbwDelta}</span>` : ''}</span>
              </div>
              <div class="perf-bar-row perf-bar-row-bottom">
                <span class="perf-bar-name" style="color:${competitorColor}">${competitor.shortLabel}</span>
                <div class="perf-bar-track">
                  <div class="perf-bar-fill" style="width:${otherPct}%;background:${competitorColor};"></div>
                </div>
                <span class="perf-bar-value" style="color:${otherValColor}">${otherLabel}${otherDelta ? ` <span class="perf-delta">${otherDelta}</span>` : ''}</span>
              </div>
            </div>
          </div>`;
      }

      html += '</div>';
    }

    html += '</div>';

    if (done) {
      let baseWins = 0;
      let otherWins = 0;
      let ties = 0;
      for (const r of allResults) {
        for (const metric of activeMetrics) {
          const t = r.tbw.get(metric);
          const c = r.competitor.get(metric);
          if (t !== undefined && c !== undefined) {
            const isMem = metric === MEMORY_METRIC;
            const isTieResult = !isMem && t < NOISE_FLOOR_MS && c < NOISE_FLOOR_MS;
            if (isTieResult) ties++;
            else if (t < c) baseWins++;
            else if (c < t) otherWins++;
            else ties++;
          }
        }
      }
      const overallRatios: number[] = [];
      for (const r of allResults) {
        for (const metric of activeMetrics) {
          if (metric === MEMORY_METRIC) continue;
          const t = r.tbw.get(metric);
          const c = r.competitor.get(metric);
          if (t !== undefined && c !== undefined && t > 0 && c > 0) {
            if (!(t < NOISE_FLOOR_MS && c < NOISE_FLOOR_MS)) overallRatios.push(c / t);
          }
        }
      }
      const overallGeoMean = overallRatios.length > 0
        ? Math.pow(overallRatios.reduce((p, r) => p * r, 1), 1 / overallRatios.length)
        : 1;
      const overallWinnerIsBase = baseWins >= otherWins;
      const overallSpeedup = overallGeoMean >= 1 ? overallGeoMean : 1 / overallGeoMean;
      const speedupLabel = overallSpeedup >= 1.05 ? ` — <strong>${overallSpeedup.toFixed(1)}× faster</strong>` : '';
      const winnerName = overallWinnerIsBase ? baselineAdapter.name : competitor.name;
      const winnerColor = overallWinnerIsBase ? COLOR_BASELINE : competitorColor;

      html += `
        <div class="perf-summary">
          <span style="color:${winnerColor}">▎${winnerName}</span> wins <strong>${Math.max(baseWins, otherWins)}/${baseWins + otherWins + ties}</strong> data points${ties > 0 ? ` · ${ties} ties` : ''}${speedupLabel}
          <div style="color:#888;font-size:12px;margin-top:4px;">
            Tested at ${SCALE_POINTS.map(formatRowCount).join(', ')} rows × ${COL_COUNT} columns · ${ITERATIONS}× iterations (trimmed mean)${hasMemoryApi ? ' — memory via Chrome performance.memory' : ''}
          </div>
        </div>
      `;
    }

    return html;
  }
  // #endregion

  // #region Benchmark Orchestrator
  runBtn.addEventListener('click', async () => {
    runBtn.disabled = true;
    competitorSelect.disabled = true;
    progressContainer.style.display = 'block';

    const competitor = currentCompetitor;

    statusEl.textContent = `Loading ${competitor.name}...`;
    try {
      await Promise.all([baselineAdapter.load(), competitor.load()]);
    } catch (err) {
      statusEl.textContent = `Failed to load ${competitor.name}`;
      console.error(err);
      runBtn.disabled = false;
      competitorSelect.disabled = false;
      progressContainer.style.display = 'none';
      return;
    }
    versionsEl.textContent = competitor.version
      ? `${competitor.name} v${competitor.version} (latest from CDN)`
      : '';

    // Warmup: run both grids at the smallest scale point to JIT-compile
    // virtualization and row-pool code paths.
    statusEl.textContent = 'Warming up...';
    gridArea.innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">Warmup...</p>';
    await baselineAdapter.runAtScale(gridArea, SCALE_POINTS[0]);
    await competitor.runAtScale(gridArea, SCALE_POINTS[0]);
    await cooldown(500);

    const allResults: ScaleResult[] = SCALE_POINTS.map((rowCount) => ({
      rowCount,
      tbw: new Map<MetricName, number>(),
      competitor: new Map<MetricName, number>(),
    }));

    const totalSteps = SCALE_POINTS.length * 2;
    let completedSteps = 0;
    const updateProgress = () => {
      const pct = Math.round((completedSteps / totalSteps) * 100);
      progressBar.style.width = `${pct}%`;
    };

    for (let i = 0; i < SCALE_POINTS.length; i++) {
      const rowCount = SCALE_POINTS[i];
      const label = formatRowCount(rowCount);

      // Phase 1: baseline at this scale point
      statusEl.textContent = `${baselineAdapter.name} — ${label} rows (${i + 1}/${SCALE_POINTS.length})`;
      gridArea.innerHTML = `<p style="text-align:center;opacity:0.6;padding:20px 0;">⏱ ${baselineAdapter.name} — ${label} rows...</p>`;
      await cooldown(200);
      allResults[i].tbw = await baselineAdapter.runAtScale(gridArea, rowCount);
      completedSteps++;
      updateProgress();
      resultsEl.innerHTML = renderScaleTable(allResults, competitor, false);

      statusEl.textContent = `Cooldown before ${competitor.name} — ${label} rows...`;
      gridArea.innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">Cooldown...</p>';
      await cooldown(1000);

      // Phase 2: competitor at this scale point
      statusEl.textContent = `${competitor.name} — ${label} rows (${i + 1}/${SCALE_POINTS.length})`;
      gridArea.innerHTML = `<p style="text-align:center;opacity:0.6;padding:20px 0;">⏱ ${competitor.name} — ${label} rows...</p>`;
      await cooldown(200);
      allResults[i].competitor = await competitor.runAtScale(gridArea, rowCount);
      completedSteps++;
      updateProgress();
      resultsEl.innerHTML = renderScaleTable(allResults, competitor, false);

      if (i < SCALE_POINTS.length - 1) {
        statusEl.textContent = `Cooldown before ${formatRowCount(SCALE_POINTS[i + 1])} rows...`;
        gridArea.innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">Cooldown...</p>';
        await cooldown(1000);
      }
    }

    // Cache + final render
    cache.set(competitor.id, allResults);
    gridArea.innerHTML = '<p style="text-align:center;opacity:0.6;padding:20px 0;">Benchmark complete</p>';
    statusEl.textContent =
      `Complete — ${SCALE_POINTS.map(formatRowCount).join(' → ')} rows` +
      (competitor.version ? ` — ${competitor.name} v${competitor.version}` : '');
    resultsEl.innerHTML = renderScaleTable(allResults, competitor, true);
    progressBar.style.width = '100%';
    runBtn.disabled = false;
    competitorSelect.disabled = false;

    // Console summary
    {
      const tableData: Record<string, Record<string, string>> = {};
      for (const metric of ALL_METRICS) {
        const row: Record<string, string> = {};
        for (const r of allResults) {
          const label = formatRowCount(r.rowCount);
          row[`${label} ${baselineAdapter.shortLabel}`] = formatMetric(metric, r.tbw.get(metric) ?? 0);
          row[`${label} ${competitor.shortLabel}`] = formatMetric(metric, r.competitor.get(metric) ?? 0);
        }
        tableData[metric] = row;
      }
      console.log(`📊 Benchmark Results — ${baselineAdapter.name} vs ${competitor.name}` + (competitor.version ? ` v${competitor.version}` : ''));
      console.table(tableData);
    }
  });
  // #endregion
</script>

<style is:global>
  .perf-compare-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 500px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    overflow: hidden;
  }

  .perf-compare-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 13px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .perf-compare-bar-left,
  .perf-compare-bar-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .perf-compare-btn {
    background: var(--sl-color-accent);
    color: #fff;
    border: none;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
  }

  .perf-compare-btn:hover { opacity: 0.9; }
  .perf-compare-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .perf-compare-select-wrap {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--sl-color-gray-2);
  }

  .perf-compare-select {
    background: var(--sl-color-gray-7, #111);
    color: var(--sl-color-white, #e5e5e5);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 13px;
    cursor: pointer;
  }

  .perf-compare-select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  #compare-status {
    font-size: 13px;
    color: var(--sl-color-gray-2);
  }

  .perf-compare-progress {
    height: 3px;
    background: var(--sl-color-gray-5);
    overflow: hidden;
  }

  .perf-compare-progress-fill {
    height: 100%;
    width: 0;
    background: var(--sl-color-accent);
    transition: width 0.3s;
  }

  .perf-compare-config {
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
  }

  .perf-compare-config summary {
    padding: 8px 12px;
    cursor: pointer;
    font-size: 13px;
    color: var(--sl-color-gray-2);
    user-select: none;
  }

  .perf-compare-config summary:hover {
    color: var(--sl-color-white);
  }

  .perf-compare-config-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 0 12px 12px;
  }

  .perf-compare-config-panel {
    background: var(--sl-color-gray-7, #111);
    border-radius: 4px;
    padding: 10px;
    overflow-x: auto;
  }

  .perf-compare-config-panel h4 {
    margin: 0 0 8px 0;
    font-size: 13px;
    color: var(--sl-color-white, #e5e5e5);
  }

  .perf-compare-config-panel pre {
    margin: 0;
    font-size: 11px;
    line-height: 1.5;
    white-space: pre-wrap;
    color: var(--sl-color-gray-2);
  }

  .perf-compare-grid-area {
    height: 300px;
    padding: 8px;
    overflow: hidden;
    position: relative;
  }

  .perf-compare-results {
    border-top: 1px solid var(--sl-color-gray-5);
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.5;
    max-height: 70vh;
    overflow-y: auto;
  }

  .perf-compare-results p {
    margin: 0 0 8px 0;
  }

  .perf-legend {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
    font-size: 12px;
    color: var(--sl-color-gray-2);
    flex-wrap: wrap;
  }

  .perf-legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-weight: 600;
    color: var(--sl-color-white, #e5e5e5);
  }

  .perf-legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
  }

  .perf-legend-hint {
    font-size: 11px;
    color: var(--sl-color-gray-3, #999);
    margin-left: auto;
  }

  .perf-card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  @media (max-width: 700px) {
    .perf-card-grid { grid-template-columns: 1fr; }
  }

  .perf-card {
    background: var(--sl-color-gray-6, #1e1e1e);
    border-radius: 6px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .perf-card-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--sl-color-white, #e5e5e5);
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .perf-card-subtitle {
    font-size: 11px;
    font-weight: 500;
    flex-shrink: 0;
  }

  .perf-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 3px 0;
  }

  .perf-row + .perf-row {
    border-top: 1px solid var(--sl-color-gray-5, #333);
  }

  .perf-row-label {
    font-family: monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--sl-color-white, #e5e5e5);
    min-width: 28px;
    text-align: right;
  }

  .perf-row-bars {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .perf-bar-row {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 16px;
